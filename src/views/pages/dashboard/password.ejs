<%- include('../../partials/header') %>
<style>
  .toast-enter { animation: toastIn 0.3s ease-out; }
  .toast-leave { animation: toastOut 0.3s ease-in forwards; }
  @keyframes toastIn { from { transform: translateX(100%); opacity: 0; } to { transform: translateX(0); opacity: 1; } }
  @keyframes toastOut { from { transform: translateX(0); opacity: 1; } to { transform: translateX(100%); opacity: 0; } }
</style>
<div id="toastContainer" class="fixed top-4 right-4 z-[100] flex flex-col gap-2 pointer-events-none" style="min-width:320px;max-width:420px"></div>
<div class="min-h-screen flex flex-col">
  <header class="bg-white border-b border-gray-200">
    <div class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between">
      <h1 class="text-xl font-bold" style="color: var(--brand-color)"><%= typeof settings !== 'undefined' && settings.site_name ? settings.site_name : 'AlumniLink' %> Dashboard</h1>
      <div class="hidden md:flex items-center gap-4">
        <% if (typeof user !== 'undefined' && user && (user.role === 'admin' || user.role === 'super_admin')) { %>
        <a href="/dashboard" class="text-sm text-gray-600 hover:underline">Dashboard</a>
        <a href="/dashboard/alumni" class="text-sm text-blue-600 hover:underline">Kelola Alumni</a>
        <% } %>
        <% if (typeof user !== 'undefined' && user && user.role === 'super_admin') { %>
          <a href="/dashboard/admins" class="text-sm text-blue-600 hover:underline">Kelola Admin</a>
          <a href="/dashboard/settings" class="text-sm text-blue-600 hover:underline">Pengaturan</a>
        <% } %>
        <div class="flex items-center gap-2 border-r border-gray-200 pr-3">
  <% if (typeof user !== 'undefined' && user) { %>
    <% if (user.photoUrl) { %>
      <img src="<%= user.photoUrl %>" class="w-7 h-7 rounded-full object-cover border border-gray-200" />
    <% } else { %>
      <div class="w-7 h-7 rounded-full bg-gradient-to-br from-blue-500 to-teal-400 flex items-center justify-center text-white font-bold text-xs"><%= (user.fullName || '?').charAt(0).toUpperCase() %></div>
    <% } %>
    <span class="text-sm text-gray-700 font-medium max-w-[120px] truncate"><%= user.fullName %></span>
  <% } %>
</div>
<a href="/logout" class="text-sm text-red-600 hover:underline">Keluar</a>
      </div>
      <button id="menuBtn" class="md:hidden p-2 rounded-lg hover:bg-gray-100 transition-colors" onclick="toggleMenu()" aria-label="Menu">
        <span class="material-symbols-outlined">menu</span>
      </button>
    </div>
  </header>
  <div class="md:hidden h-0.5" style="background: linear-gradient(135deg, var(--gradient-from), var(--gradient-to));"></div>

  <!-- Mobile menu -->
  <div id="mobileMenu" class="fixed inset-0 z-[60] hidden md:hidden">
    <div class="absolute inset-0 bg-black/40" onclick="toggleMenu()"></div>
    <div class="absolute right-0 top-0 h-full w-72 max-w-[85vw] bg-white shadow-2xl">
      <div class="flex items-center justify-between p-4 border-b border-gray-200">
        <span class="font-semibold text-gray-900">Menu</span>
        <button onclick="toggleMenu()" class="p-1 rounded-lg hover:bg-gray-100 transition-colors">
          <span class="material-symbols-outlined">close</span>
        </button>
      </div>
      <nav class="p-4 flex flex-col gap-1">
        <% if (typeof user !== 'undefined' && user) { %>
        <div class="flex items-center gap-3 px-4 py-3 border-b border-gray-100 mb-1 pb-3">
          <% if (user.photoUrl) { %>
            <img src="<%= user.photoUrl %>" class="w-10 h-10 rounded-full object-cover border border-gray-200" />
          <% } else { %>
            <div class="w-10 h-10 rounded-full bg-gradient-to-br from-blue-500 to-teal-400 flex items-center justify-center text-white font-bold text-sm"><%= (user.fullName || '?').charAt(0).toUpperCase() %></div>
          <% } %>
          <div class="min-w-0">
            <p class="text-sm font-medium text-gray-900 truncate"><%= user.fullName %></p>
            <p class="text-xs text-gray-500 truncate"><%= user.email || '' %></p>
          </div>
        </div>
        <% } %>
        <% if (typeof user !== 'undefined' && user && (user.role === 'admin' || user.role === 'super_admin')) { %>
        <a href="/dashboard" class="flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-gray-600 hover:bg-gray-50">Dashboard</a>
        <a href="/dashboard/alumni" class="flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-gray-600 hover:bg-gray-50">Kelola Alumni</a>
        <% } %>
        <a href="/dashboard/password" class="flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium bg-blue-50 text-blue-600">Ubah Password</a>
        <% if (typeof user !== 'undefined' && user && user.role === 'super_admin') { %>
          <a href="/dashboard/admins" class="flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-gray-600 hover:bg-gray-50">Kelola Admin</a>
          <a href="/dashboard/settings" class="flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-gray-600 hover:bg-gray-50">Pengaturan</a>
        <% } %>
        <hr class="my-2 border-gray-200" />
        <a href="/logout" class="flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-red-600 hover:bg-red-50">Keluar</a>
      </nav>
    </div>
  </div>

  <section class="py-10 px-4" style="background: linear-gradient(135deg, var(--gradient-from), var(--gradient-to));">
    <div class="max-w-6xl mx-auto">
      <a href="/dashboard" class="text-sm text-white/80 hover:text-white">&larr; Dashboard</a>
      <h2 class="text-2xl font-bold text-white mt-1">Ubah Password</h2>
    </div>
  </section>

  <main class="flex-1 max-w-2xl mx-auto px-4 py-8 w-full">
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg text-sm mb-4"><%= error %></div>
    <% } %>
    <% if (typeof success !== 'undefined' && success) { %>
      <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-lg text-sm mb-4"><%= success %></div>
    <% } %>

    <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6">
      <form id="passwordForm" class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Password Saat Ini</label>
          <div class="relative">
            <input type="password" id="currentPassword" required class="w-full px-3 py-2 pr-10 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" />
            <button type="button" onclick="toggleField('currentPassword','eyeCurrent')" class="absolute right-2 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600 p-1">
              <span id="eyeCurrent" class="material-symbols-outlined" style="font-size:20px">visibility</span>
            </button>
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Password Baru</label>
          <div class="relative">
            <input type="password" id="newPassword" required minlength="6" class="w-full px-3 py-2 pr-10 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" />
            <button type="button" onclick="toggleField('newPassword','eyeNew')" class="absolute right-2 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600 p-1">
              <span id="eyeNew" class="material-symbols-outlined" style="font-size:20px">visibility</span>
            </button>
          </div>
        </div>
        <button type="submit" class="w-full py-2 bg-blue-600 text-white rounded-lg font-medium hover:bg-blue-700">Ubah Password</button>
      </form>
    </div>
  </main>
</div>

<script>
function toggleMenu() {
  var menu = document.getElementById('mobileMenu');
  menu.classList.toggle('hidden');
  document.body.classList.toggle('overflow-hidden');
}
function toggleField(inputId, iconId) {
  var input = document.getElementById(inputId);
  var icon = document.getElementById(iconId);
  if (input.type === 'password') { input.type = 'text'; icon.textContent = 'visibility_off'; }
  else { input.type = 'password'; icon.textContent = 'visibility'; }
}

function escapeHtml(str) {
  var d = document.createElement('div'); d.textContent = str; return d.innerHTML;
}
function showToast(message, type) {
  type = type || 'info';
  var colors = {
    success: { bg: 'bg-green-50', border: 'border-green-200', text: 'text-green-800', icon: 'check_circle', iconBg: 'bg-green-100', iconColor: 'text-green-600' },
    error:   { bg: 'bg-red-50',    border: 'border-red-200',   text: 'text-red-800',   icon: 'error',         iconBg: 'bg-red-100',   iconColor: 'text-red-600' },
    warning: { bg: 'bg-yellow-50', border: 'border-yellow-200', text: 'text-yellow-800', icon: 'warning',       iconBg: 'bg-yellow-100', iconColor: 'text-yellow-600' },
    info:    { bg: 'bg-blue-50',   border: 'border-blue-200',  text: 'text-blue-800',  icon: 'info',          iconBg: 'bg-blue-100',  iconColor: 'text-blue-600' },
  };
  var c = colors[type] || colors.info;
  var container = document.getElementById('toastContainer');
  var el = document.createElement('div');
  el.className = 'pointer-events-auto toast-enter ' + c.bg + ' ' + c.border + ' border rounded-xl shadow-lg px-4 py-3 flex items-start gap-3';
  el.innerHTML =
    '<div class="w-8 h-8 rounded-full ' + c.iconBg + ' flex items-center justify-center flex-shrink-0">' +
      '<span class="material-symbols-outlined ' + c.iconColor + '" style="font-size:18px">' + c.icon + '</span>' +
    '</div>' +
    '<p class="text-sm ' + c.text + ' flex-1 pt-0.5">' + escapeHtml(message) + '</p>' +
    '<button onclick="this.closest(\'div\').classList.add(\'toast-leave\');setTimeout(function(){this.closest(\'div\').remove()}.bind(this),300)" class="flex-shrink-0 ' + c.text + ' hover:opacity-70">' +
      '<span class="material-symbols-outlined" style="font-size:16px">close</span>' +
    '</button>';
  container.appendChild(el);
  setTimeout(function() {
    if (el.parentNode) { el.classList.add('toast-leave'); setTimeout(function() { if (el.parentNode) el.remove(); }, 300); }
  }, 4000);
}

document.getElementById('passwordForm').addEventListener('submit', async function(e) {
  e.preventDefault();
  var token = '<%= typeof token !== 'undefined' ? token : '' %>';
  var currentPassword = document.getElementById('currentPassword').value;
  var newPassword = document.getElementById('newPassword').value;

  try {
    var res = await fetch('/api/v1/auth/password', {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
      body: JSON.stringify({ currentPassword, newPassword }),
    });
    var data = await res.json();
    if (data.success) {
      showToast('Password berhasil diubah!', 'success');
      var dest = '<%= typeof user !== 'undefined' && user && user.role === 'user' ? '/alumni' : '/dashboard' %>';
      setTimeout(function() { window.location.href = dest; }, 800);
    } else {
      showToast(data.error || 'Gagal mengubah password', 'error');
    }
  } catch (e) {
    showToast('Terjadi kesalahan: ' + e.message, 'error');
  }
});
</script>
<%- include('../../partials/footer') %>