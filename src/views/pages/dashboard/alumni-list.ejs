<%- include('../../partials/header') %>
<style>
  .soft-gradient { background: linear-gradient(135deg, var(--gradient-from), var(--gradient-to)); }
  .glass-card { background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(8px); border: 1px solid rgba(226, 232, 240, 0.5); }
  .toast-enter { animation: toastIn 0.3s ease-out; }
  .toast-leave { animation: toastOut 0.3s ease-in forwards; }
  @keyframes toastIn { from { transform: translateX(100%); opacity: 0; } to { transform: translateX(0); opacity: 1; } }
  @keyframes toastOut { from { transform: translateX(0); opacity: 1; } to { transform: translateX(100%); opacity: 0; } }
  .modal-overlay { animation: fadeIn 0.2s ease-out; }
  @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
</style>

<div id="toastContainer" class="fixed top-4 right-4 z-[100] flex flex-col gap-2 pointer-events-none" style="min-width:320px;max-width:420px"></div>

<div id="confirmModal" class="fixed inset-0 z-[99] hidden items-center justify-center modal-overlay">
  <div class="absolute inset-0 bg-black/40" onclick="closeConfirm()"></div>
  <div class="relative bg-white rounded-2xl shadow-xl p-6 mx-4 max-w-sm w-full">
    <div class="flex items-start gap-4">
      <div id="confirmIcon" class="w-10 h-10 rounded-full flex items-center justify-center flex-shrink-0 bg-blue-100">
        <span class="material-symbols-outlined text-blue-600" style="font-size:22px">info</span>
      </div>
      <div class="flex-1 min-w-0">
        <p id="confirmMessage" class="text-sm text-gray-800 font-medium"></p>
        <p id="confirmHint" class="text-xs text-gray-500 mt-1"></p>
      </div>
    </div>
    <div id="confirmCheckboxWrap" class="hidden mt-4 flex items-center gap-2">
      <input id="confirmCheckbox" type="checkbox" class="w-4 h-4 text-red-600 rounded border-gray-300 focus:ring-red-500" />
      <label id="confirmCheckboxLabel" for="confirmCheckbox" class="text-xs text-gray-600"></label>
    </div>
    <div class="flex justify-end gap-2 mt-4">
      <button onclick="closeConfirm()" class="px-4 py-2 text-sm font-medium text-gray-600 bg-gray-100 hover:bg-gray-200 rounded-lg transition-colors">Batal</button>
      <button id="confirmOkBtn" class="px-4 py-2 text-sm font-medium text-white rounded-lg transition-colors">Ya</button>
    </div>
  </div>
</div>
<div class="min-h-screen flex flex-col">
  <header class="bg-white border-b border-gray-200">
    <div class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between">
      <h1 class="text-xl font-bold" style="color: var(--brand-color)"><%= typeof settings !== 'undefined' && settings.site_name ? settings.site_name : 'AlumniLink' %> Dashboard</h1>
      <div class="hidden md:flex items-center gap-4">
        <a href="/dashboard" class="text-sm text-gray-600 hover:underline">Dashboard</a>
        <% if (typeof user !== 'undefined' && user && user.role === 'super_admin') { %>
          <a href="/dashboard/settings" class="text-sm text-blue-600 hover:underline">Pengaturan</a>
        <% } %>
        <a href="/logout" class="text-sm text-red-600 hover:underline">Keluar</a>
      </div>
      <button id="menuBtn" class="md:hidden p-2 rounded-lg hover:bg-gray-100 transition-colors" onclick="toggleMenu()" aria-label="Menu">
        <span class="material-symbols-outlined">menu</span>
      </button>
    </div>
  </header>
  <div class="md:hidden h-0.5" style="background: linear-gradient(135deg, var(--gradient-from), var(--gradient-to));"></div>

  <!-- Mobile menu -->
  <div id="mobileMenu" class="fixed inset-0 z-[60] hidden md:hidden">
    <div class="absolute inset-0 bg-black/40" onclick="toggleMenu()"></div>
    <div class="absolute right-0 top-0 h-full w-72 max-w-[85vw] bg-white shadow-2xl">
      <div class="flex items-center justify-between p-4 border-b border-gray-200">
        <span class="font-semibold text-gray-900">Menu</span>
        <button onclick="toggleMenu()" class="p-1 rounded-lg hover:bg-gray-100 transition-colors">
          <span class="material-symbols-outlined">close</span>
        </button>
      </div>
      <nav class="p-4 flex flex-col gap-1">
        <a href="/dashboard" class="flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-gray-600 hover:bg-gray-50">Dashboard</a>
        <a href="/dashboard/alumni" class="flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium bg-blue-50 text-blue-600">Kelola Alumni</a>
        <a href="/dashboard/password" class="flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-gray-600 hover:bg-gray-50">Ubah Password</a>
        <% if (typeof user !== 'undefined' && user && user.role === 'super_admin') { %>
          <a href="/dashboard/admins" class="flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-gray-600 hover:bg-gray-50">Kelola Admin</a>
          <a href="/dashboard/settings" class="flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-gray-600 hover:bg-gray-50">Pengaturan</a>
        <% } %>
        <hr class="my-2 border-gray-200" />
        <a href="/logout" class="flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-red-600 hover:bg-red-50">Keluar</a>
      </nav>
    </div>
  </div>

  <section class="soft-gradient py-10 px-4 relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-0 left-0 w-64 h-64 bg-white rounded-full blur-3xl -translate-x-1/2 -translate-y-1/2"></div>
      <div class="absolute bottom-0 right-0 w-96 h-96 bg-white rounded-full blur-3xl translate-x-1/3 translate-y-1/3"></div>
    </div>
    <div class="max-w-6xl mx-auto relative z-10">
      <div class="flex items-center justify-between">
        <div>
          <a href="/dashboard" class="text-sm text-white/80 hover:text-white">&larr; Dashboard</a>
          <h2 class="text-2xl font-bold text-white mt-1">Kelola Alumni</h2>
        </div>
        <a href="/dashboard/alumni/new" class="px-5 py-2.5 bg-white text-blue-600 rounded-xl text-sm font-semibold hover:bg-blue-50 transition-all shadow-lg flex items-center gap-2">
          <span class="material-symbols-outlined" style="font-size:18px">add</span>Tambah Alumni
        </a>
      </div>
    </div>
  </section>

  <main class="flex-1 max-w-6xl mx-auto px-4 py-8 w-full">
    <form method="GET" class="flex flex-col sm:flex-row gap-2 sm:gap-3 mb-6">
      <input type="text" name="search" placeholder="Cari nama, NIK, atau email..." value="<%= typeof search !== 'undefined' ? search : '' %>" class="w-full sm:flex-1 px-4 py-2.5 border border-gray-300 rounded-xl text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none bg-white" />
      <div class="flex gap-2 sm:gap-3">
        <select name="isActive" class="flex-1 sm:flex-none px-4 py-2.5 border border-gray-300 rounded-xl text-sm bg-white focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none">
          <option value="">Semua Status</option>
          <option value="active" <%= typeof statusFilter !== 'undefined' && statusFilter === 'active' ? 'selected' : '' %>>Aktif</option>
          <option value="inactive" <%= typeof statusFilter !== 'undefined' && statusFilter === 'inactive' ? 'selected' : '' %>>Non-Aktif</option>
        </select>
        <select name="limit" onchange="this.form.submit()" class="flex-none px-4 py-2.5 border border-gray-300 rounded-xl text-sm bg-white focus:ring-2 focus:ring-blue-500 outline-none">
          <% [5, 10, 20, 50, 100].forEach(function(n) { %>
            <option value="<%= n %>" <%= typeof limit !== 'undefined' && limit === n ? 'selected' : '' %>><%= n %></option>
          <% }); %>
        </select>
        <button type="submit" class="flex-none px-5 py-2.5 bg-blue-600 text-white rounded-xl text-sm font-medium hover:bg-blue-700 transition-all flex items-center gap-2">
          <span class="material-symbols-outlined" style="font-size:18px">search</span><span class="hidden sm:inline">Cari</span>
        </button>
      </div>
    </form>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg text-sm mb-4"><%= error %></div>
    <% } %>

    <div id="bulkBar" class="hidden bg-blue-50 border border-blue-200 rounded-xl px-4 py-3 mb-4 flex items-center justify-between">
      <span class="text-sm text-blue-700"><span id="selectedCount">0</span> alumni dipilih</span>
      <div class="flex gap-2">
        <button onclick="bulkActivate()" class="px-3 py-1.5 bg-green-600 text-white rounded-lg text-xs font-medium hover:bg-green-700">Aktifkan</button>
        <button onclick="bulkDeactivate()" class="px-3 py-1.5 bg-yellow-500 text-white rounded-lg text-xs font-medium hover:bg-yellow-600">Nonaktifkan</button>
        <button onclick="bulkDelete()" class="px-3 py-1.5 bg-red-600 text-white rounded-lg text-xs font-medium hover:bg-red-700">Hapus</button>
      </div>
    </div>

    <div class="glass-card rounded-2xl overflow-hidden shadow-sm bg-white/90">
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-gray-50 border-b border-gray-200">
            <th class="px-4 py-3.5 w-10">
              <input type="checkbox" id="selectAll" class="w-4 h-4 text-blue-600 rounded border-gray-300 focus:ring-blue-500" />
            </th>
            <th class="text-left px-4 py-3.5 text-xs font-semibold text-gray-500 uppercase tracking-wider">Nama</th>
            <th class="text-left px-4 py-3.5 text-xs font-semibold text-gray-500 uppercase tracking-wider hidden md:table-cell">Email</th>
            <th class="text-left px-4 py-3.5 text-xs font-semibold text-gray-500 uppercase tracking-wider hidden md:table-cell">Provinsi</th>
            <th class="text-left px-4 py-3.5 text-xs font-semibold text-gray-500 uppercase tracking-wider hidden lg:table-cell">Status Alumni</th>
            <th class="text-left px-4 py-3.5 text-xs font-semibold text-gray-500 uppercase tracking-wider hidden lg:table-cell">Aktif</th>
            <th class="text-right px-4 py-3.5 text-xs font-semibold text-gray-500 uppercase tracking-wider">Aksi</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% if (typeof alumni !== 'undefined' && alumni.length) { alumni.forEach(function(a) { %>
            <tr class="hover:bg-gray-50/50 transition-colors">
              <% 
                var _admMap = JSON.parse(typeof adminRoleMapJson !== 'undefined' ? adminRoleMapJson : '{}');
                var _admInfo = a.email ? _admMap[a.email.toLowerCase()] : undefined;
                var _sameLevel = _admInfo && (_admInfo.isBuiltin || _admInfo.role === user.role);
              %>
              <td class="px-4 py-3.5">
                <input type="checkbox" class="alumni-check w-4 h-4 text-blue-600 rounded border-gray-300 focus:ring-blue-500" value="<%= a.id %>" />
              </td>
              <td class="px-4 py-3.5">
                <div class="flex items-center gap-3">
                  <div class="w-8 h-8 rounded-full flex-shrink-0 overflow-hidden">
                    <% if (a.photoUrl) { %>
                      <img src="<%= a.photoUrl %>" alt="<%= a.name %>" class="w-full h-full object-cover" />
                    <% } else { %>
                      <div class="w-full h-full bg-gradient-to-br from-blue-500 to-teal-400 flex items-center justify-center">
                        <span class="text-white font-bold text-xs"><%= (a.name || '?').charAt(0).toUpperCase() %></span>
                      </div>
                    <% } %>
                  </div>
                  <div>
                    <span class="font-medium text-gray-900"><%= a.name %></span>
                    <% if (a.institutionName) { %><p class="text-xs text-gray-400"><%= a.institutionName %></p><% } %>
                  </div>
                </div>
              </td>
              <td class="px-4 py-3.5 text-gray-500 hidden md:table-cell"><%= a.email || '-' %></td>
              <td class="px-4 py-3.5 hidden md:table-cell">
                <span class="inline-flex px-2.5 py-1 bg-gray-100 text-gray-600 rounded-full text-xs"><%= a.province || '-' %></span>
              </td>
              <td class="px-4 py-3.5 hidden lg:table-cell">
                <span class="inline-flex px-2.5 py-1 <%= a.careerStatus === 'Pekerja' ? 'bg-blue-100 text-blue-700' : a.careerStatus === 'Wirausaha' ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-600' %> rounded-full text-xs font-medium"><%= a.careerStatus || '-' %></span>
              </td>
              <td class="px-4 py-3.5 hidden lg:table-cell">
                <% if (!_sameLevel) { %>
                <button onclick="toggleStatus('<%= a.id %>', <%= a.isActive !== false %>)" class="inline-flex items-center gap-1 px-3 py-1.5 rounded-lg text-xs font-medium transition-colors <%= a.isActive !== false ? 'bg-green-50 text-green-600 hover:bg-green-100' : 'bg-red-50 text-red-600 hover:bg-red-100' %>">
                  <span class="material-symbols-outlined" style="font-size:14px"><%= a.isActive !== false ? 'check_circle' : 'cancel' %></span>
                  <%= a.isActive !== false ? 'Aktif' : 'Nonaktif' %>
                </button>
                <% } else { %>
                <span class="inline-flex px-2.5 py-1 rounded-lg text-xs font-medium <%= a.isActive !== false ? 'bg-green-50 text-green-600' : 'bg-red-50 text-red-600' %>"><%= a.isActive !== false ? 'Aktif' : 'Nonaktif' %></span>
                <% } %>
              </td>
              <td class="px-4 py-3.5 text-right">
                <div class="flex flex-col sm:flex-row items-end sm:items-center justify-end gap-1 sm:gap-2">
                  <% if (!_sameLevel) { %>
                  <a href="/dashboard/alumni/<%= a.id %>/edit" class="inline-flex items-center gap-1 px-3 py-1.5 bg-amber-50 text-amber-600 rounded-lg text-xs font-medium hover:bg-amber-100 transition-colors whitespace-nowrap">
                    <span class="material-symbols-outlined" style="font-size:14px">edit</span>Edit
                  </a>
                  <% } %>
                  <a href="/alumni/<%= a.id %>" class="inline-flex items-center gap-1 px-3 py-1.5 bg-blue-50 text-blue-600 rounded-lg text-xs font-medium hover:bg-blue-100 transition-colors whitespace-nowrap">
                    Lihat<span class="material-symbols-outlined" style="font-size:14px">open_in_new</span>
                  </a>
                  <% if (!_sameLevel) { %>
                  <button onclick="deleteAlumni('<%= a.id %>', <%= _admInfo ? 'true' : 'false' %>)" class="inline-flex items-center gap-1 px-3 py-1.5 bg-red-50 text-red-600 rounded-lg text-xs font-medium hover:bg-red-100 transition-colors whitespace-nowrap">
                    <span class="material-symbols-outlined" style="font-size:14px">delete</span>Hapus
                  </button>
                  <% } %>
                </div>
              </td>
            </tr>
          <% }); } else { %>
            <tr><td colspan="8" class="text-center py-12 text-gray-400">
              <span class="material-symbols-outlined text-3xl mb-2 block">people_outline</span>
              Belum ada data alumni
            </td></tr>
          <% } %>
        </tbody>
      </table>
    </div>

    <% if (typeof totalPages !== 'undefined' && totalPages > 1) { %>
      <div class="flex items-center justify-center gap-2 mt-6">
        <% if (page > 1) { %>
          <a href="?page=<%= page - 1 %>&limit=<%= limit %><%= search ? '&search=' + search : '' %>" class="px-3 py-1.5 border border-gray-300 rounded-lg text-sm hover:bg-gray-100">&laquo; Prev</a>
        <% } %>
        <span class="text-sm text-gray-500">Halaman <%= page %> dari <%= totalPages %></span>
        <% if (page < totalPages) { %>
          <a href="?page=<%= page + 1 %>&limit=<%= limit %><%= search ? '&search=' + search : '' %>" class="px-3 py-1.5 border border-gray-300 rounded-lg text-sm hover:bg-gray-100">Next &raquo;</a>
        <% } %>
      </div>
    <% } %>
  </main>
</div>

<script>
function toggleMenu() {
  var menu = document.getElementById('mobileMenu');
  menu.classList.toggle('hidden');
  document.body.classList.toggle('overflow-hidden');
}

var token = '<%= typeof token !== 'undefined' ? token : '' %>';

// --- Toast ---
function showToast(message, type) {
  type = type || 'info';
  var colors = {
    success: { bg: 'bg-green-50', border: 'border-green-200', text: 'text-green-800', icon: 'check_circle', iconBg: 'bg-green-100', iconColor: 'text-green-600' },
    error:   { bg: 'bg-red-50',    border: 'border-red-200',   text: 'text-red-800',   icon: 'error',         iconBg: 'bg-red-100',   iconColor: 'text-red-600' },
    warning: { bg: 'bg-yellow-50', border: 'border-yellow-200', text: 'text-yellow-800', icon: 'warning',       iconBg: 'bg-yellow-100', iconColor: 'text-yellow-600' },
    info:    { bg: 'bg-blue-50',   border: 'border-blue-200',  text: 'text-blue-800',  icon: 'info',          iconBg: 'bg-blue-100',  iconColor: 'text-blue-600' },
  };
  var c = colors[type] || colors.info;
  var container = document.getElementById('toastContainer');
  var el = document.createElement('div');
  el.className = 'pointer-events-auto toast-enter ' + c.bg + ' ' + c.border + ' border rounded-xl shadow-lg px-4 py-3 flex items-start gap-3';
  el.innerHTML =
    '<div class="w-8 h-8 rounded-full ' + c.iconBg + ' flex items-center justify-center flex-shrink-0">' +
      '<span class="material-symbols-outlined ' + c.iconColor + '" style="font-size:18px">' + c.icon + '</span>' +
    '</div>' +
    '<p class="text-sm ' + c.text + ' flex-1 pt-0.5">' + escapeHtml(message) + '</p>' +
    '<button onclick="this.closest(\'div\').classList.add(\'toast-leave\');setTimeout(function(){this.closest(\'div\').remove()}.bind(this),300)" class="flex-shrink-0 ' + c.text + ' hover:opacity-70">' +
      '<span class="material-symbols-outlined" style="font-size:16px">close</span>' +
    '</button>';
  container.appendChild(el);
  setTimeout(function() {
    if (el.parentNode) { el.classList.add('toast-leave'); setTimeout(function() { if (el.parentNode) el.remove(); }, 300); }
  }, 4000);
}

// --- Confirm Modal ---
var confirmResolve = null;

function showConfirm(message, hint, iconType, checkboxLabel) {
  iconType = iconType || 'info';
  var iconMap = {
    danger: { icon: 'warning', bg: 'bg-red-100', color: 'text-red-600', btn: 'bg-red-600 hover:bg-red-700' },
    warning: { icon: 'warning', bg: 'bg-yellow-100', color: 'text-yellow-600', btn: 'bg-yellow-500 hover:bg-yellow-600' },
    info: { icon: 'info', bg: 'bg-blue-100', color: 'text-blue-600', btn: 'bg-blue-600 hover:bg-blue-700' },
  };
  var m = iconMap[iconType] || iconMap.info;
  document.getElementById('confirmIcon').className = 'w-10 h-10 rounded-full flex items-center justify-center flex-shrink-0 ' + m.bg;
  document.getElementById('confirmIcon').innerHTML = '<span class="material-symbols-outlined ' + m.color + '" style="font-size:22px">' + m.icon + '</span>';
  document.getElementById('confirmMessage').textContent = message;
  document.getElementById('confirmHint').textContent = hint || '';
  document.getElementById('confirmOkBtn').className = 'px-4 py-2 text-sm font-medium text-white rounded-lg transition-colors ' + m.btn;
  var cw = document.getElementById('confirmCheckboxWrap');
  if (checkboxLabel) {
    document.getElementById('confirmCheckbox').checked = false;
    document.getElementById('confirmCheckboxLabel').textContent = checkboxLabel;
    cw.classList.remove('hidden');
  } else {
    cw.classList.add('hidden');
  }
  document.getElementById('confirmModal').classList.remove('hidden');
  document.getElementById('confirmModal').classList.add('flex');
  return new Promise(function(resolve) { confirmResolve = resolve; });
}

function closeConfirm() { document.getElementById('confirmModal').classList.add('hidden'); document.getElementById('confirmModal').classList.remove('flex'); if (confirmResolve) { confirmResolve(false); confirmResolve = null; } }

document.getElementById('confirmOkBtn').addEventListener('click', function() { document.getElementById('confirmModal').classList.add('hidden'); document.getElementById('confirmModal').classList.remove('flex'); if (confirmResolve) { confirmResolve(true); confirmResolve = null; } });
function isConfirmChecked() { return document.getElementById('confirmCheckbox').checked; }

// --- Escape HTML ---
function escapeHtml(str) {
  var d = document.createElement('div');
  d.textContent = str;
  return d.innerHTML;
}

// --- Select All ---
document.getElementById('selectAll').addEventListener('change', function() {
  document.querySelectorAll('.alumni-check').forEach(function(cb) {
    cb.checked = this.checked;
  }, this);
  updateBulkBar();
});

document.querySelectorAll('.alumni-check').forEach(function(cb) {
  cb.addEventListener('change', updateBulkBar);
});

function getSelectedIds() {
  var ids = [];
  document.querySelectorAll('.alumni-check:checked').forEach(function(cb) {
    ids.push(cb.value);
  });
  return ids;
}

function updateBulkBar() {
  var selected = getSelectedIds();
  var bar = document.getElementById('bulkBar');
  var count = document.getElementById('selectedCount');
  if (selected.length) {
    bar.classList.remove('hidden');
    count.textContent = selected.length;
  } else {
    bar.classList.add('hidden');
  }
}

// --- Bulk Status ---
async function bulkActivate() { await bulkStatus(true); }
async function bulkDeactivate() { await bulkStatus(false); }

async function bulkStatus(active) {
  var ids = getSelectedIds();
  if (!ids.length) return;
  var label = active ? 'mengaktifkan' : 'menonaktifkan';
  var ok = await showConfirm(label + ' ' + ids.length + ' alumni?', null, 'warning');
  if (!ok) return;
  try {
    var res = await fetch('/api/v1/alumni/bulk/status', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
      body: JSON.stringify({ ids: ids, isActive: active }),
    });
    var data = await res.json();
    if (data.success) {
      showToast('Status ' + ids.length + ' alumni berhasil diperbarui', 'success');
      setTimeout(function() { location.reload(); }, 800);
    } else showToast(data.error || 'Gagal', 'error');
  } catch (e) {
    showToast('Terjadi kesalahan: ' + e.message, 'error');
  }
}

// --- Bulk Delete ---
async function bulkDelete() {
  var ids = getSelectedIds();
  if (!ids.length) return;
  var ok = await showConfirm('Hapus ' + ids.length + ' alumni?', 'Data terkait (pendidikan, sertifikat, dll) akan ikut terhapus.', 'danger');
  if (!ok) return;
  try {
    var res = await fetch('/api/v1/alumni/bulk/delete', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
      body: JSON.stringify({ ids: ids }),
    });
    var data = await res.json();
    if (data.success) {
      if (data.blocked && data.blocked.length) {
        showToast(data.message, 'warning');
      } else {
        showToast(data.deleted + ' alumni berhasil dihapus', 'success');
      }
      setTimeout(function() { location.reload(); }, 800);
    } else showToast(data.error || 'Gagal menghapus', 'error');
  } catch (e) {
    showToast('Terjadi kesalahan: ' + e.message, 'error');
  }
}

async function toggleStatus(id, current) {
  var label = current ? 'non-aktif' : 'aktif';
  var ok = await showConfirm('Ubah status alumni ini menjadi ' + label + '?', null, 'warning');
  if (!ok) return;
  try {
    var res = await fetch('/api/v1/alumni/' + id + '/status', {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
      body: JSON.stringify({ isActive: !current }),
    });
    var data = await res.json();
    if (data.success) {
      showToast('Status alumni berhasil diubah', 'success');
      setTimeout(function() { location.reload(); }, 800);
    } else showToast(data.error || 'Gagal mengubah status', 'error');
  } catch (e) {
    showToast('Terjadi kesalahan: ' + e.message, 'error');
  }
}

async function deleteAlumni(id, isAdmin) {
  var checkboxLabel = isAdmin ? 'Juga hapus akun adminnya' : null;
  var ok = await showConfirm('Hapus alumni ini?', 'Data terkait (pendidikan, sertifikat, dll) akan ikut terhapus.', 'danger', checkboxLabel);
  if (!ok) return;
  var deleteAdmin = isConfirmChecked();
  try {
    var url = '/api/v1/alumni/' + id;
    if (deleteAdmin) url += '?deleteAdmin=1';
    var res = await fetch(url, {
      method: 'DELETE',
      headers: { 'Authorization': 'Bearer ' + token },
    });
    var data = await res.json();
    if (data.success) {
      showToast('Alumni berhasil dihapus', 'success');
      setTimeout(function() { location.reload(); }, 800);
    } else showToast(data.error || 'Gagal menghapus alumni', 'error');
  } catch (e) {
    showToast('Terjadi kesalahan: ' + e.message, 'error');
  }
}
</script>
