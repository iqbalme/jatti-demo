<%- include('../../partials/header') %>
<div class="min-h-screen flex flex-col">
  <header class="bg-white border-b border-gray-200">
    <div class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between">
      <h1 class="text-xl font-bold" style="color: var(--brand-color)"><%= typeof settings !== 'undefined' && settings.site_name ? settings.site_name : 'AlumniLink' %> Dashboard</h1>
      <div class="hidden md:flex items-center gap-4">
        <a href="/dashboard/alumni" class="text-sm text-blue-600 hover:underline">Kelola Alumni</a>
        <% if (typeof user !== 'undefined' && user && user.role === 'super_admin') { %>
          <a href="/dashboard/admins" class="text-sm text-blue-600 hover:underline">Kelola Admin</a>
          <a href="/dashboard/settings" class="text-sm text-blue-600 hover:underline">Pengaturan</a>
        <% } %>
        <a href="/dashboard/password" class="text-sm text-gray-600 hover:underline">Ubah Password</a>
        <a href="/logout" class="text-sm text-red-600 hover:underline">Keluar</a>
      </div>
      <button id="menuBtn" class="md:hidden p-2 rounded-lg hover:bg-gray-100 transition-colors" onclick="toggleMenu()" aria-label="Menu">
        <span class="material-symbols-outlined">menu</span>
      </button>
    </div>
  </header>
  <div class="md:hidden h-0.5" style="background: linear-gradient(135deg, var(--gradient-from), var(--gradient-to));"></div>

  <!-- Mobile menu -->
  <div id="mobileMenu" class="fixed inset-0 z-[60] hidden md:hidden">
    <div class="absolute inset-0 bg-black/40" onclick="toggleMenu()"></div>
    <div class="absolute right-0 top-0 h-full w-72 max-w-[85vw] bg-white shadow-2xl">
      <div class="flex items-center justify-between p-4 border-b border-gray-200">
        <span class="font-semibold text-gray-900">Menu</span>
        <button onclick="toggleMenu()" class="p-1 rounded-lg hover:bg-gray-100 transition-colors">
          <span class="material-symbols-outlined">close</span>
        </button>
      </div>
      <nav class="p-4 flex flex-col gap-1">
        <a href="/dashboard" class="flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium bg-blue-50 text-blue-600">Dashboard</a>
        <a href="/dashboard/alumni" class="flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-gray-600 hover:bg-gray-50">Kelola Alumni</a>
        <a href="/dashboard/password" class="flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-gray-600 hover:bg-gray-50">Ubah Password</a>
        <% if (typeof user !== 'undefined' && user && user.role === 'super_admin') { %>
          <a href="/dashboard/admins" class="flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-gray-600 hover:bg-gray-50">Kelola Admin</a>
          <a href="/dashboard/settings" class="flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-gray-600 hover:bg-gray-50">Pengaturan</a>
        <% } %>
        <hr class="my-2 border-gray-200" />
        <a href="/logout" class="flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-red-600 hover:bg-red-50">Keluar</a>
      </nav>
    </div>
  </div>

  <main class="flex-1 max-w-6xl mx-auto px-4 py-8 w-full">
    <h2 class="text-2xl font-bold text-gray-900 mb-6">Dashboard</h2>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg text-sm mb-4"><%= error %></div>
    <% } %>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-8">
      <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
        <p class="text-sm text-gray-500 mb-1">Total Alumni</p>
        <p class="text-3xl font-bold text-gray-900"><%= typeof totalAlumni !== 'undefined' ? totalAlumni : 0 %></p>
      </div>
      <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
        <p class="text-sm text-gray-500 mb-1">Aktif</p>
        <p class="text-3xl font-bold text-green-600"><%= typeof totalActive !== 'undefined' ? totalActive : 0 %></p>
      </div>
      <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
        <p class="text-sm text-gray-500 mb-1">Non-Aktif</p>
        <p class="text-3xl font-bold text-red-500"><%= typeof totalInactive !== 'undefined' ? totalInactive : 0 %></p>
      </div>
    </div>

    <div class="grid sm:grid-cols-2 gap-4 mb-8">
      <a href="/dashboard/alumni/new" class="block bg-white rounded-xl shadow-sm border border-gray-200 p-6 hover:shadow-md transition-shadow">
        <span class="material-symbols-outlined text-blue-600 mb-2">add</span>
        <h3 class="font-semibold text-gray-900">Tambah Alumni Baru</h3>
        <p class="text-sm text-gray-500 mt-1">Masukkan data alumni baru</p>
      </a>
      <a href="/alumni" class="block bg-white rounded-xl shadow-sm border border-gray-200 p-6 hover:shadow-md transition-shadow">
        <span class="material-symbols-outlined text-blue-600 mb-2">visibility</span>
        <h3 class="font-semibold text-gray-900">Lihat Directory Publik</h3>
        <p class="text-sm text-gray-500 mt-1">Lihat halaman alumni publik</p>
      </a>
    </div>

    <% if (typeof labels !== 'undefined' && labels.length > 0) { %>
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4 sm:p-6">
      <div class="flex items-center justify-between mb-4">
        <h3 class="font-semibold text-gray-900">Alumni per Provinsi</h3>
        <a href="/statistik" class="text-sm" style="color: var(--brand-color);">Lihat detail &rarr;</a>
      </div>
      <div class="hidden md:block">
        <canvas id="dashBarChart" height="<%= Math.max(160, labels.length * 28) %>"></canvas>
      </div>
      <div class="block md:hidden max-w-xs mx-auto">
        <canvas id="dashPieChart"></canvas>
      </div>
    </div>
    <% } %>
  </main>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4"></script>
<script>
(function() {
  var labels = <%- JSON.stringify(typeof labels !== 'undefined' ? labels : []) %>;
  var values = <%- JSON.stringify(typeof values !== 'undefined' ? values : []) %>;
  if (labels.length === 0) return;

  var root = document.documentElement;
  var fromColor = getComputedStyle(root).getPropertyValue('--gradient-from').trim() || '#2563eb';
  var toColor = getComputedStyle(root).getPropertyValue('--gradient-to').trim() || '#2dd4bf';

  function hexToRgb(hex) {
    var result = /^#?([a-f\d]{2})([a-f\d]{2})([a-f\d]{2})$/i.exec(hex);
    return result ? { r: parseInt(result[1], 16), g: parseInt(result[2], 16), b: parseInt(result[3], 16) } : { r: 37, g: 99, b: 235 };
  }

  var from = hexToRgb(fromColor);
  var to = hexToRgb(toColor);

  var bgColors = labels.map(function(_, i) {
    var t = labels.length > 1 ? i / (labels.length - 1) : 0.5;
    var r = Math.round(from.r + (to.r - from.r) * t);
    var g = Math.round(from.g + (to.g - from.g) * t);
    var b = Math.round(from.b + (to.b - from.b) * t);
    return 'rgba(' + r + ',' + g + ',' + b + ',0.8)';
  });

  var barCtx = document.getElementById('dashBarChart');
  if (barCtx) {
    new Chart(barCtx, {
      type: 'bar',
      data: {
        labels: labels,
        datasets: [{
          label: 'Jumlah',
          data: values,
          backgroundColor: bgColors,
          borderColor: bgColors.map(function(c) { return c.replace('0.8', '1'); }),
          borderWidth: 1
        }]
      },
      options: {
        indexAxis: 'y',
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { display: false } },
        scales: {
          x: { ticks: { stepSize: 1, font: { size: 11 } }, title: { display: true, text: 'Jumlah Alumni', font: { size: 11 } } },
          y: { ticks: { font: { size: 11 } } }
        }
      }
    });
  }

  var pieCtx = document.getElementById('dashPieChart');
  if (pieCtx) {
    new Chart(pieCtx, {
      type: 'doughnut',
      data: {
        labels: labels,
        datasets: [{ data: values, backgroundColor: bgColors, borderColor: '#ffffff', borderWidth: 2 }]
      },
      options: {
        responsive: true,
        plugins: {
          legend: { position: 'bottom', labels: { font: { size: 10 }, padding: 8 } }
        }
      }
    });
  }
})();
</script>

<script>
function toggleMenu() {
  var menu = document.getElementById('mobileMenu');
  menu.classList.toggle('hidden');
  document.body.classList.toggle('overflow-hidden');
}
</script>
<%- include('../../partials/footer') %>
