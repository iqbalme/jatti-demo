<%- include('../../partials/header') %>
<style>
  .soft-gradient { background: linear-gradient(135deg, var(--gradient-from), var(--gradient-to)); }
  .glass-card { background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(8px); border: 1px solid rgba(226, 232, 240, 0.5); }
  .toast-enter { animation: toastIn 0.3s ease-out; }
  .toast-leave { animation: toastOut 0.3s ease-in forwards; }
  @keyframes toastIn { from { transform: translateX(100%); opacity: 0; } to { transform: translateX(0); opacity: 1; } }
  @keyframes toastOut { from { transform: translateX(0); opacity: 1; } to { transform: translateX(100%); opacity: 0; } }
  .modal-overlay { animation: fadeIn 0.2s ease-out; }
  @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
</style>

<div id="toastContainer" class="fixed top-4 right-4 z-[100] flex flex-col gap-2 pointer-events-none" style="min-width:320px;max-width:420px"></div>

<div id="confirmModal" class="fixed inset-0 z-[99] hidden items-center justify-center modal-overlay">
  <div class="absolute inset-0 bg-black/40" onclick="closeConfirm()"></div>
  <div class="relative bg-white rounded-2xl shadow-xl p-6 mx-4 max-w-sm w-full">
    <div class="flex items-start gap-4">
      <div id="confirmIcon" class="w-10 h-10 rounded-full flex items-center justify-center flex-shrink-0 bg-blue-100">
        <span class="material-symbols-outlined text-blue-600" style="font-size:22px">info</span>
      </div>
      <div class="flex-1 min-w-0">
        <p id="confirmMessage" class="text-sm text-gray-800 font-medium"></p>
        <p id="confirmHint" class="text-xs text-gray-500 mt-1"></p>
      </div>
    </div>
    <div class="flex justify-end gap-2 mt-5">
      <button onclick="closeConfirm()" class="px-4 py-2 text-sm font-medium text-gray-600 bg-gray-100 hover:bg-gray-200 rounded-lg transition-colors">Batal</button>
      <button id="confirmOkBtn" class="px-4 py-2 text-sm font-medium text-white rounded-lg transition-colors">Ya</button>
    </div>
  </div>
</div>

<% %>

<div class="min-h-screen flex flex-col">
  <header class="bg-white border-b border-gray-200">
    <div class="max-w-4xl mx-auto px-4 py-4 flex items-center justify-between">
      <h1 class="text-xl font-bold" style="color: var(--brand-color)"><%= typeof settings !== 'undefined' && settings.site_name ? settings.site_name : 'AlumniLink' %> Dashboard</h1>
      <div class="hidden md:flex items-center gap-4">
        <a href="/dashboard" class="text-sm text-gray-600 hover:underline">Dashboard</a>
        <a href="/dashboard/alumni" class="text-sm text-gray-600 hover:underline">Kelola Alumni</a>
        <% if (typeof user !== 'undefined' && user && user.role === 'super_admin') { %>
          <a href="/dashboard/settings" class="text-sm text-blue-600 hover:underline">Pengaturan</a>
        <% } %>
        <a href="/logout" class="text-sm text-red-600 hover:underline">Keluar</a>
      </div>
      <button id="menuBtn" class="md:hidden p-2 rounded-lg hover:bg-gray-100 transition-colors" onclick="toggleMenu()" aria-label="Menu">
        <span class="material-symbols-outlined">menu</span>
      </button>
    </div>
  </header>
  <div class="md:hidden h-0.5" style="background: linear-gradient(135deg, var(--gradient-from), var(--gradient-to));"></div>

  <!-- Mobile menu -->
  <div id="mobileMenu" class="fixed inset-0 z-[60] hidden md:hidden">
    <div class="absolute inset-0 bg-black/40" onclick="toggleMenu()"></div>
    <div class="absolute right-0 top-0 h-full w-72 max-w-[85vw] bg-white shadow-2xl">
      <div class="flex items-center justify-between p-4 border-b border-gray-200">
        <span class="font-semibold text-gray-900">Menu</span>
        <button onclick="toggleMenu()" class="p-1 rounded-lg hover:bg-gray-100 transition-colors">
          <span class="material-symbols-outlined">close</span>
        </button>
      </div>
      <nav class="p-4 flex flex-col gap-1">
        <a href="/dashboard" class="flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-gray-600 hover:bg-gray-50">Dashboard</a>
        <a href="/dashboard/alumni" class="flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-gray-600 hover:bg-gray-50">Kelola Alumni</a>
        <a href="/dashboard/password" class="flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-gray-600 hover:bg-gray-50">Ubah Password</a>
        <% if (typeof user !== 'undefined' && user && user.role === 'super_admin') { %>
          <a href="/dashboard/admins" class="flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-gray-600 hover:bg-gray-50">Kelola Admin</a>
          <a href="/dashboard/settings" class="flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-gray-600 hover:bg-gray-50">Pengaturan</a>
        <% } %>
        <hr class="my-2 border-gray-200" />
        <a href="/logout" class="flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-red-600 hover:bg-red-50">Keluar</a>
      </nav>
    </div>
  </div>

  <section class="soft-gradient py-12 px-4 relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-0 left-0 w-64 h-64 bg-white rounded-full blur-3xl -translate-x-1/2 -translate-y-1/2"></div>
      <div class="absolute bottom-0 right-0 w-96 h-96 bg-white rounded-full blur-3xl translate-x-1/3 translate-y-1/3"></div>
    </div>
    <div class="max-w-4xl mx-auto relative z-10 text-center">
      <h1 class="text-3xl font-bold text-white mb-2"><%= typeof a !== 'undefined' && a ? 'Edit' : 'Tambah' %> Data Alumni</h1>
      <p class="text-white/80"><%= typeof a !== 'undefined' && a ? 'Perbarui data diri alumni' : 'Isi formulir data diri alumni secara lengkap.' %></p>
    </div>
  </section>

  <main class="flex-1 max-w-4xl mx-auto px-4 py-8 w-full">
    <a href="/dashboard/alumni" class="text-sm text-blue-600 hover:underline mb-4 inline-block">&larr; Kembali ke daftar</a>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg text-sm mb-4"><%= error %></div>
    <% } %>

    <form id="alumniForm" action="/dashboard/alumni/new" method="POST" class="space-y-6">
      <div id="formMessage" class="hidden p-4 rounded-lg text-sm"></div>

      <!-- SECTION 1: Data Pribadi -->
      <div class="glass-card rounded-2xl p-6 shadow-sm border border-gray-200/50 bg-white/90">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-lg bg-blue-100 flex items-center justify-center">
            <span class="material-symbols-outlined text-blue-600">badge</span>
          </div>
          <h2 class="text-lg font-semibold">Data Pribadi</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          <div>
            <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1.5" for="nik">NIK <span class="text-red-500">*</span></label>
            <input class="w-full px-4 py-2.5 rounded-xl border border-gray-300 bg-white text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" id="nik" name="nik" placeholder="16 digit NIK" required type="text" maxlength="16" value="<%= typeof a !== 'undefined' && a ? a.nik || '' : '' %>" />
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1.5" for="name">Nama Lengkap <span class="text-red-500">*</span></label>
            <input class="w-full px-4 py-2.5 rounded-xl border border-gray-300 bg-white text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" id="name" name="name" placeholder="Nama lengkap sesuai KTP" required type="text" value="<%= typeof a !== 'undefined' && a ? a.name || '' : '' %>" />
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1.5">Jenis Kelamin <span class="text-red-500">*</span></label>
            <div class="flex gap-4 pt-1.5">
              <label class="flex items-center gap-2 cursor-pointer text-sm"><input class="w-4 h-4 text-blue-600" name="gender" required type="radio" value="Laki-laki" <%= typeof a !== 'undefined' && a && a.gender === 'Laki-laki' ? 'checked' : '' %> /><span>Laki-laki</span></label>
              <label class="flex items-center gap-2 cursor-pointer text-sm"><input class="w-4 h-4 text-blue-600" name="gender" type="radio" value="Perempuan" <%= typeof a !== 'undefined' && a && a.gender === 'Perempuan' ? 'checked' : '' %> /><span>Perempuan</span></label>
            </div>
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1.5" for="maritalStatus">Status Pernikahan <span class="text-red-500">*</span></label>
            <select class="w-full px-4 py-2.5 rounded-xl border border-gray-300 bg-white text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" id="maritalStatus" name="maritalStatus" required>
              <option value="">Pilih status</option>
              <option value="Belum Menikah" <%= typeof a !== 'undefined' && a && a.maritalStatus === 'Belum Menikah' ? 'selected' : '' %>>Belum Menikah</option>
              <option value="Menikah" <%= typeof a !== 'undefined' && a && a.maritalStatus === 'Menikah' ? 'selected' : '' %>>Menikah</option>
              <option value="Pernah Menikah (Duda/Janda)" <%= typeof a !== 'undefined' && a && a.maritalStatus === 'Pernah Menikah (Duda/Janda)' ? 'selected' : '' %>>Pernah Menikah (Duda/Janda)</option>
            </select>
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1.5" for="phone">No. HP/WhatsApp <span class="text-red-500">*</span></label>
            <input class="w-full px-4 py-2.5 rounded-xl border border-gray-300 bg-white text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" id="phone" name="phone" placeholder="+62 812-3456-7890" required type="tel" value="<%= typeof a !== 'undefined' && a ? a.phone || '' : '' %>" />
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1.5" for="email">Email Aktif <span class="text-red-500">*</span></label>
            <input class="w-full px-4 py-2.5 rounded-xl border border-gray-300 bg-white text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" id="email" name="email" placeholder="nama@email.com" required type="email" value="<%= typeof a !== 'undefined' && a ? a.email || '' : '' %>" />
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1.5">Link Media Sosial</label>
            <div class="flex gap-2 mb-2">
              <input class="flex-1 px-4 py-2.5 rounded-xl border border-gray-300 bg-white text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" id="socialLinkInput" placeholder="https://linkedin.com/in/username" type="url" />
              <button class="px-4 py-2.5 bg-gray-100 text-gray-700 rounded-xl text-sm font-medium hover:bg-gray-200 transition-all" id="addSocialBtn" type="button">Tambah</button>
            </div>
            <div class="flex flex-wrap gap-1.5" id="socialLinksContainer"></div>
            <input id="socialLinks" name="socialLinks" type="hidden" />
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1.5" for="photo">Foto</label>
            <input class="w-full px-4 py-2.5 rounded-xl border border-gray-300 bg-white text-sm file:mr-3 file:py-1.5 file:px-3 file:rounded-lg file:border-0 file:bg-blue-100 file:text-blue-700 file:text-xs file:font-semibold" id="photo" name="photo" accept="image/*" type="file" />
            <p class="text-xs text-gray-400 mt-1">Format: JPEG, PNG, GIF, WebP. Maksimal <%= typeof maxFileSizeKb !== 'undefined' && maxFileSizeKb ? maxFileSizeKb : 500 %>KB.</p>
            <div id="photoPreview" class="mt-2 hidden">
              <img class="w-20 h-20 rounded-xl object-cover border border-gray-300" id="photoPreviewImg" alt="Preview" />
              <button type="button" id="removePhotoBtn" class="mt-1.5 text-xs text-red-600 hover:text-red-700 font-medium hidden">Hapus Foto</button>
            </div>
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1.5">Provinsi <span class="text-red-500">*</span></label>
            <select class="w-full px-4 py-2.5 rounded-xl border border-gray-300 bg-white text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" id="provinceCode" required>
              <option value="">Pilih provinsi</option>
            </select>
            <input id="provinceName" name="province" type="hidden" />
            <input id="regencyName" name="regencyName" type="hidden" />
            <input id="districtName" name="districtName" type="hidden" />
            <input id="villageName" name="villageName" type="hidden" />
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1.5">Kabupaten</label>
            <select class="w-full px-4 py-2.5 rounded-xl border border-gray-300 bg-white text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" id="regencyCode">
              <option value="">Pilih kabupaten</option>
            </select>
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1.5">Kecamatan</label>
            <select class="w-full px-4 py-2.5 rounded-xl border border-gray-300 bg-white text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" id="districtCode">
              <option value="">Pilih kecamatan</option>
            </select>
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1.5">Kelurahan</label>
            <select class="w-full px-4 py-2.5 rounded-xl border border-gray-300 bg-white text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" id="villageCode">
              <option value="">Pilih kelurahan</option>
            </select>
          </div>
          <div class="md:col-span-2">
            <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1.5" for="address">Alamat Domisili Lengkap <span class="text-red-500">*</span></label>
            <textarea class="w-full px-4 py-2.5 rounded-xl border border-gray-300 bg-white text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none resize-none" id="address" name="address" placeholder="RT/RW, Kelurahan, Kecamatan, Kota/Kabupaten, Kode Pos" rows="3"><%= typeof a !== 'undefined' && a ? a.address || '' : '' %></textarea>
          </div>
        </div>
      </div>

      <!-- SECTION 2: Pendidikan -->
      <div class="glass-card rounded-2xl p-6 shadow-sm border border-gray-200/50 bg-white/90">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-lg bg-blue-100 flex items-center justify-center">
            <span class="material-symbols-outlined text-blue-600">school</span>
          </div>
          <h2 class="text-lg font-semibold">Latar Belakang Pendidikan</h2>
        </div>
        <p class="text-sm text-gray-500 mb-4">Tambahkan riwayat pendidikan dari jenjang S1 sampai S3</p>
        <div id="educationContainer" class="space-y-4"></div>
        <button class="mt-3 px-6 py-2.5 border-2 border-dashed border-gray-300 rounded-xl text-gray-500 text-sm font-medium hover:bg-gray-50 hover:border-blue-400 transition-all w-full flex items-center justify-center gap-2" id="addEducationBtn" type="button">
          <span class="material-symbols-outlined">add</span>Tambah Riwayat Pendidikan
        </button>
      </div>

      <!-- SECTION 3: Sertifikat -->
      <div class="glass-card rounded-2xl p-6 shadow-sm border border-gray-200/50 bg-white/90">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-lg bg-blue-100 flex items-center justify-center">
            <span class="material-symbols-outlined text-blue-600">verified</span>
          </div>
          <h2 class="text-lg font-semibold">Sertifikat Kompetensi</h2>
        </div>
        <div id="certificateContainer" class="space-y-4"></div>
        <button class="mt-3 px-6 py-2.5 border-2 border-dashed border-gray-300 rounded-xl text-gray-500 text-sm font-medium hover:bg-gray-50 hover:border-blue-400 transition-all w-full flex items-center justify-center gap-2" id="addCertificateBtn" type="button">
          <span class="material-symbols-outlined">add</span>Tambah Sertifikat
        </button>
      </div>

      <!-- SECTION 4: Organisasi -->
      <div class="glass-card rounded-2xl p-6 shadow-sm border border-gray-200/50 bg-white/90">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-lg bg-blue-100 flex items-center justify-center">
            <span class="material-symbols-outlined text-blue-600">groups</span>
          </div>
          <h2 class="text-lg font-semibold">Pengalaman Organisasi</h2>
        </div>
        <div id="organizationContainer" class="space-y-4"></div>
        <button class="mt-3 px-6 py-2.5 border-2 border-dashed border-gray-300 rounded-xl text-gray-500 text-sm font-medium hover:bg-gray-50 hover:border-blue-400 transition-all w-full flex items-center justify-center gap-2" id="addOrgBtn" type="button">
          <span class="material-symbols-outlined">add</span>Tambah Pengalaman Organisasi
        </button>
      </div>

      <!-- SECTION 4.5: Portfolio -->
      <div class="glass-card rounded-2xl p-6 shadow-sm border border-gray-200/50 bg-white/90">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-lg bg-blue-100 flex items-center justify-center">
            <span class="material-symbols-outlined text-blue-600">folder</span>
          </div>
          <h2 class="text-lg font-semibold">Portofolio</h2>
        </div>
        <p class="text-sm text-gray-500 mb-4">Tambahkan portofolio karya (buku, aplikasi, website, dll)</p>
        <div id="portfolioContainer" class="space-y-4"></div>
        <button class="mt-3 px-6 py-2.5 border-2 border-dashed border-gray-300 rounded-xl text-gray-500 text-sm font-medium hover:bg-gray-50 hover:border-blue-400 transition-all w-full flex items-center justify-center gap-2" id="addPortfolioBtn" type="button">
          <span class="material-symbols-outlined">add</span>Tambah Portofolio
        </button>
      </div>

      <!-- SECTION 5: Karir -->
      <div class="glass-card rounded-2xl p-6 shadow-sm border border-gray-200/50 bg-white/90">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-lg bg-blue-100 flex items-center justify-center">
            <span class="material-symbols-outlined text-blue-600">work</span>
          </div>
          <h2 class="text-lg font-semibold">Profil Pekerjaan / Karir</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          <div>
            <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1.5" for="careerStatus">Status Pekerjaan Saat Ini <span class="text-red-500">*</span></label>
            <select class="w-full px-4 py-2.5 rounded-xl border border-gray-300 bg-white text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" id="careerStatus" name="careerStatus" required>
              <option value="">Pilih status</option>
              <option value="Pekerja" <%= typeof a !== 'undefined' && a && a.careerStatus === 'Pekerja' ? 'selected' : '' %>>Pekerja</option>
              <option value="Wirausaha" <%= typeof a !== 'undefined' && a && a.careerStatus === 'Wirausaha' ? 'selected' : '' %>>Wirausaha</option>
              <option value="Profesional" <%= typeof a !== 'undefined' && a && a.careerStatus === 'Profesional' ? 'selected' : '' %>>Profesional (Pengacara, Dokter, Insinyur, Konsultan, dll)</option>
              <option value="Tenaga Pendidik" <%= typeof a !== 'undefined' && a && a.careerStatus === 'Tenaga Pendidik' ? 'selected' : '' %>>Tenaga Pendidik</option>
              <option value="Pencari Kerja" <%= typeof a !== 'undefined' && a && a.careerStatus === 'Pencari Kerja' ? 'selected' : '' %>>Pencari Kerja</option>
              <option value="Lainnya" <%= typeof a !== 'undefined' && a && a.careerStatus === 'Lainnya' ? 'selected' : '' %>>Lainnya</option>
            </select>
          </div>
          <div id="careerOtherWrapper" class="hidden">
            <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1.5" for="careerOther">Sebutkan <span class="text-red-500">*</span></label>
            <input class="w-full px-4 py-2.5 rounded-xl border border-gray-300 bg-white text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" id="careerOther" name="careerOther" placeholder="Jabatan/profesi lainnya" type="text" value="<%= typeof a !== 'undefined' && a ? a.careerOther || '' : '' %>" />
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1.5" for="institutionName">Nama Instansi/Perusahaan</label>
            <input class="w-full px-4 py-2.5 rounded-xl border border-gray-300 bg-white text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" id="institutionName" name="institutionName" placeholder="Nama perusahaan/instansi" type="text" value="<%= typeof a !== 'undefined' && a ? a.institutionName || '' : '' %>" />
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1.5" for="institutionField">Bidang Instansi/Perusahaan</label>
            <input class="w-full px-4 py-2.5 rounded-xl border border-gray-300 bg-white text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" id="institutionField" name="institutionField" placeholder="Contoh: Teknologi Informasi" type="text" value="<%= typeof a !== 'undefined' && a ? a.institutionField || '' : '' %>" />
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1.5" for="position">Jabatan</label>
            <input class="w-full px-4 py-2.5 rounded-xl border border-gray-300 bg-white text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" id="position" name="position" placeholder="Contoh: Senior Software Engineer" type="text" value="<%= typeof a !== 'undefined' && a ? a.position || '' : '' %>" />
          </div>
        </div>
      </div>

      <!-- Status Alumni -->
      <div class="glass-card rounded-2xl p-6 shadow-sm border border-gray-200/50 bg-white/90">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 rounded-lg bg-blue-100 flex items-center justify-center">
            <span class="material-symbols-outlined text-blue-600">toggle_on</span>
          </div>
          <h2 class="text-lg font-semibold">Status Alumni</h2>
        </div>
        <div class="flex items-center gap-3">
          <label class="relative inline-flex items-center cursor-pointer">
            <input type="checkbox" id="isActiveToggle" class="sr-only peer" <%= typeof a !== 'undefined' && a ? (a.isActive !== false ? 'checked' : '') : 'checked' %> />
            <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-blue-300 rounded-full peer peer-checked:after:translate-x-full rtl:peer-checked:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-blue-600"></div>
            <span class="ms-3 text-sm font-medium text-gray-700" id="isActiveLabel"><%= typeof a !== 'undefined' && a ? (a.isActive !== false ? 'Aktif' : 'Nonaktif') : 'Aktif' %></span>
          </label>
          <input type="hidden" name="isActive" id="isActiveInput" value="<%= typeof a !== 'undefined' && a ? (a.isActive !== false ? 'true' : 'false') : 'true' %>" />
        </div>
      </div>

      <!-- SECTION 6: Usaha -->
      <div class="glass-card rounded-2xl p-6 shadow-sm border border-gray-200/50 bg-white/90">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-lg bg-blue-100 flex items-center justify-center">
            <span class="material-symbols-outlined text-blue-600">store</span>
          </div>
          <h2 class="text-lg font-semibold">Data Usaha</h2>
        </div>
        <p class="text-sm text-gray-500 mb-4">Isi jika memiliki usaha (bisa lebih dari satu)</p>
        <div id="businessContainer" class="space-y-4"></div>
        <button class="mt-3 px-6 py-2.5 border-2 border-dashed border-gray-300 rounded-xl text-gray-500 text-sm font-medium hover:bg-gray-50 hover:border-blue-400 transition-all w-full flex items-center justify-center gap-2" id="addBusinessBtn" type="button">
          <span class="material-symbols-outlined">add</span>Tambah Data Usaha
        </button>
      </div>

      <!-- Submit -->
      <div class="flex flex-col md:flex-row gap-4">
        <button class="flex-1 bg-blue-600 text-white py-3 px-6 rounded-xl font-semibold text-sm hover:bg-blue-700 transition-all shadow-lg shadow-blue-600/20 flex items-center justify-center gap-2" type="submit">
          <span class="material-symbols-outlined">save</span><%= typeof a !== 'undefined' && a ? 'Perbarui' : 'Simpan' %> Data Alumni
        </button>
        <a class="flex-1 bg-gray-200 text-gray-700 py-3 px-6 rounded-xl font-semibold text-sm hover:bg-gray-300 transition-all flex items-center justify-center gap-2" href="/dashboard/alumni">
          <span class="material-symbols-outlined">cancel</span>Batal
        </a>
      </div>

      <!-- Admin Actions: Reset Password & Jadikan Admin -->
      <% if (typeof user !== 'undefined' && user && (user.role === 'admin' || user.role === 'super_admin') && typeof a !== 'undefined' && a) { %>
      <div class="glass-card rounded-2xl p-6 shadow-sm border border-gray-200/50 bg-white/90 mt-6">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 rounded-lg bg-red-100 flex items-center justify-center">
            <span class="material-symbols-outlined text-red-600">admin_panel_settings</span>
          </div>
          <h2 class="text-lg font-semibold">Tindakan Admin</h2>
        </div>
        <p class="text-sm text-gray-500 mb-4">Fitur untuk manajemen akun alumni ini</p>
        <div class="flex flex-wrap gap-3">
          <% if (!isAlreadyAdmin) { %>
          <button type="button" onclick="resetPassword('<%= a.id %>')" class="flex items-center gap-2 px-4 py-2.5 bg-red-500 text-white rounded-xl text-sm font-medium hover:bg-red-600 shadow-lg shadow-red-500/20">
            <span class="material-symbols-outlined" style="font-size:18px">lock_reset</span>Reset Password
          </button>
          <% } %>
          <% if (user.role === 'super_admin' && !isAlreadyAdmin) { %>
          <button type="button" onclick="makeAdmin('<%= a.id %>')" class="flex items-center gap-2 px-4 py-2.5 bg-purple-600 text-white rounded-xl text-sm font-medium hover:bg-purple-700 shadow-lg shadow-purple-600/20">
            <span class="material-symbols-outlined" style="font-size:18px">admin_panel_settings</span>Jadikan Admin
          </button>
          <% } %>
          <% if (isAlreadyAdmin) { %>
          <p class="text-sm text-gray-500 italic">Alumni ini sudah terdaftar sebagai admin</p>
          <% } %>
        </div>
      </div>
      <% } %>
    </form>
  </main>
</div>

