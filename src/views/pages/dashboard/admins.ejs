<%- include('../../partials/header') %>
<style>
  .toast-enter { animation: toastIn 0.3s ease-out; }
  .toast-leave { animation: toastOut 0.3s ease-in forwards; }
  @keyframes toastIn { from { transform: translateX(100%); opacity: 0; } to { transform: translateX(0); opacity: 1; } }
  @keyframes toastOut { from { transform: translateX(0); opacity: 1; } to { transform: translateX(100%); opacity: 0; } }
  .modal-overlay { animation: fadeIn 0.2s ease-out; }
  @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
</style>
<div id="toastContainer" class="fixed top-4 right-4 z-[100] flex flex-col gap-2 pointer-events-none" style="min-width:320px;max-width:420px"></div>

<div id="confirmModal" class="fixed inset-0 z-[99] hidden items-center justify-center modal-overlay">
  <div class="absolute inset-0 bg-black/40" onclick="closeConfirm()"></div>
  <div class="relative bg-white rounded-2xl shadow-xl p-6 mx-4 max-w-sm w-full">
    <div class="flex items-start gap-4">
      <div id="confirmIcon" class="w-10 h-10 rounded-full flex items-center justify-center flex-shrink-0 bg-blue-100">
        <span class="material-symbols-outlined text-blue-600" style="font-size:22px">info</span>
      </div>
      <div class="flex-1 min-w-0">
        <p id="confirmMessage" class="text-sm text-gray-800 font-medium"></p>
        <p id="confirmHint" class="text-xs text-gray-500 mt-1"></p>
      </div>
    </div>
    <div class="flex justify-end gap-2 mt-5">
      <button onclick="closeConfirm()" class="px-4 py-2 text-sm font-medium text-gray-600 bg-gray-100 hover:bg-gray-200 rounded-lg transition-colors">Batal</button>
      <button id="confirmOkBtn" class="px-4 py-2 text-sm font-medium text-white rounded-lg transition-colors">Ya</button>
    </div>
  </div>
</div>

<div class="min-h-screen flex flex-col">
  <header class="bg-white border-b border-gray-200">
    <div class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between">
      <h1 class="text-xl font-bold" style="color: var(--brand-color)"><%= typeof settings !== 'undefined' && settings.site_name ? settings.site_name : 'AlumniLink' %> Dashboard</h1>
      <div class="flex items-center gap-4">
        <a href="/dashboard" class="text-sm text-gray-600 hover:underline">Dashboard</a>
        <a href="/dashboard/alumni" class="text-sm text-blue-600 hover:underline">Kelola Alumni</a>
        <a href="/dashboard/password" class="text-sm text-gray-600 hover:underline">Ubah Password</a>
        <a href="/dashboard/settings" class="text-sm text-blue-600 hover:underline">Pengaturan</a>
        <a href="/logout" class="text-sm text-red-600 hover:underline">Keluar</a>
      </div>
    </div>
  </header>

  <section class="py-10 px-4" style="background: linear-gradient(135deg, var(--gradient-from), var(--gradient-to));">
    <div class="max-w-6xl mx-auto">
      <div class="flex items-center justify-between">
        <div>
          <a href="/dashboard" class="text-sm text-white/80 hover:text-white">&larr; Dashboard</a>
          <h2 class="text-2xl font-bold text-white mt-1">Kelola Admin</h2>
        </div>
        <a href="/dashboard/admins/new" class="px-5 py-2.5 bg-white text-blue-600 rounded-xl text-sm font-semibold hover:bg-blue-50 transition-all shadow-lg flex items-center gap-2">
          <span class="material-symbols-outlined" style="font-size:18px">add</span>Tambah Admin
        </a>
      </div>
    </div>
  </section>

  <main class="flex-1 max-w-6xl mx-auto px-4 py-8 w-full">
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg text-sm mb-4"><%= error %></div>
    <% } %>

    <div class="bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden">
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-gray-50 border-b border-gray-200">
            <th class="text-left px-4 py-3.5 text-xs font-semibold text-gray-500 uppercase tracking-wider">Nama</th>
            <th class="text-left px-4 py-3.5 text-xs font-semibold text-gray-500 uppercase tracking-wider">Email</th>
            <th class="text-left px-4 py-3.5 text-xs font-semibold text-gray-500 uppercase tracking-wider">Role</th>
            <th class="text-left px-4 py-3.5 text-xs font-semibold text-gray-500 uppercase tracking-wider">Tipe</th>
            <th class="text-right px-4 py-3.5 text-xs font-semibold text-gray-500 uppercase tracking-wider">Aksi</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% if (typeof admins !== 'undefined' && admins.length) { admins.forEach(function(a) { %>
            <tr class="hover:bg-gray-50/50 transition-colors">
              <td class="px-4 py-3.5 font-medium text-gray-900"><%= a.name %></td>
              <td class="px-4 py-3.5 text-gray-500"><%= a.email %></td>
              <td class="px-4 py-3.5">
                <span class="inline-flex px-2.5 py-1 <%= a.role === 'super_admin' ? 'bg-purple-100 text-purple-700' : 'bg-blue-100 text-blue-700' %> rounded-full text-xs font-medium"><%= a.role === 'super_admin' ? 'Super Admin' : 'Admin' %></span>
              </td>
              <td class="px-4 py-3.5">
                <% if (a.isBuiltin) { %>
                  <span class="inline-flex px-2.5 py-1 bg-gray-100 text-gray-600 rounded-full text-xs">Built-in</span>
                <% } else { %>
                  <span class="inline-flex px-2.5 py-1 bg-green-100 text-green-600 rounded-full text-xs">Database</span>
                <% } %>
              </td>
              <td class="px-4 py-3.5 text-right">
                <div class="flex items-center justify-end gap-2">
                  <% if (!a.isBuiltin) { %>
                    <button onclick="changeRole('<%= a.id %>', '<%= a.role === 'super_admin' ? 'admin' : 'super_admin' %>')" class="inline-flex items-center gap-1 px-3 py-1.5 bg-amber-50 text-amber-600 rounded-lg text-xs font-medium hover:bg-amber-100 transition-colors">
                      <%= a.role === 'super_admin' ? '\u2B07 ' : '\u2B06 ' %><%= a.role === 'super_admin' ? 'Turunkan' : 'Naikkan' %>
                    </button>
                    <button onclick="deleteAdmin('<%= a.id %>')" class="inline-flex items-center gap-1 px-3 py-1.5 bg-red-50 text-red-600 rounded-lg text-xs font-medium hover:bg-red-100 transition-colors">
                      <span class="material-symbols-outlined" style="font-size:14px">delete</span>Hapus
                    </button>
                  <% } else { %>
                    <span class="text-xs text-gray-400">Tidak bisa diubah</span>
                  <% } %>
                </div>
              </td>
            </tr>
          <% }); } else { %>
            <tr><td colspan="5" class="text-center py-12 text-gray-400">
              <span class="material-symbols-outlined text-3xl mb-2 block">admin_panel_settings</span>
              Belum ada admin
            </td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </main>
</div>

<script>
var token = '<%= typeof token !== 'undefined' ? token : '' %>';

function escapeHtml(str) {
  var d = document.createElement('div'); d.textContent = str; return d.innerHTML;
}
function showToast(message, type) {
  type = type || 'info';
  var colors = {
    success: { bg: 'bg-green-50', border: 'border-green-200', text: 'text-green-800', icon: 'check_circle', iconBg: 'bg-green-100', iconColor: 'text-green-600' },
    error:   { bg: 'bg-red-50',    border: 'border-red-200',   text: 'text-red-800',   icon: 'error',         iconBg: 'bg-red-100',   iconColor: 'text-red-600' },
    warning: { bg: 'bg-yellow-50', border: 'border-yellow-200', text: 'text-yellow-800', icon: 'warning',       iconBg: 'bg-yellow-100', iconColor: 'text-yellow-600' },
    info:    { bg: 'bg-blue-50',   border: 'border-blue-200',  text: 'text-blue-800',  icon: 'info',          iconBg: 'bg-blue-100',  iconColor: 'text-blue-600' },
  };
  var c = colors[type] || colors.info;
  var container = document.getElementById('toastContainer');
  var el = document.createElement('div');
  el.className = 'pointer-events-auto toast-enter ' + c.bg + ' ' + c.border + ' border rounded-xl shadow-lg px-4 py-3 flex items-start gap-3';
  el.innerHTML =
    '<div class="w-8 h-8 rounded-full ' + c.iconBg + ' flex items-center justify-center flex-shrink-0">' +
      '<span class="material-symbols-outlined ' + c.iconColor + '" style="font-size:18px">' + c.icon + '</span>' +
    '</div>' +
    '<p class="text-sm ' + c.text + ' flex-1 pt-0.5">' + escapeHtml(message) + '</p>' +
    '<button onclick="this.closest(\'div\').classList.add(\'toast-leave\');setTimeout(function(){this.closest(\'div\').remove()}.bind(this),300)" class="flex-shrink-0 ' + c.text + ' hover:opacity-70">' +
      '<span class="material-symbols-outlined" style="font-size:16px">close</span>' +
    '</button>';
  container.appendChild(el);
  setTimeout(function() {
    if (el.parentNode) { el.classList.add('toast-leave'); setTimeout(function() { if (el.parentNode) el.remove(); }, 300); }
  }, 4000);
}

var confirmResolve = null;
function showConfirm(message, hint, iconType) {
  iconType = iconType || 'info';
  var iconMap = {
    danger: { icon: 'warning', bg: 'bg-red-100', color: 'text-red-600', btn: 'bg-red-600 hover:bg-red-700' },
    warning: { icon: 'warning', bg: 'bg-yellow-100', color: 'text-yellow-600', btn: 'bg-yellow-500 hover:bg-yellow-600' },
    info: { icon: 'info', bg: 'bg-blue-100', color: 'text-blue-600', btn: 'bg-blue-600 hover:bg-blue-700' },
  };
  var m = iconMap[iconType] || iconMap.info;
  document.getElementById('confirmIcon').className = 'w-10 h-10 rounded-full flex items-center justify-center flex-shrink-0 ' + m.bg;
  document.getElementById('confirmIcon').innerHTML = '<span class="material-symbols-outlined ' + m.color + '" style="font-size:22px">' + m.icon + '</span>';
  document.getElementById('confirmMessage').textContent = message;
  document.getElementById('confirmHint').textContent = hint || '';
  document.getElementById('confirmOkBtn').className = 'px-4 py-2 text-sm font-medium text-white rounded-lg transition-colors ' + m.btn;
  document.getElementById('confirmModal').classList.remove('hidden');
  document.getElementById('confirmModal').classList.add('flex');
  return new Promise(function(resolve) { confirmResolve = resolve; });
}
function closeConfirm() { document.getElementById('confirmModal').classList.add('hidden'); document.getElementById('confirmModal').classList.remove('flex'); if (confirmResolve) { confirmResolve(false); confirmResolve = null; } }
document.getElementById('confirmOkBtn').addEventListener('click', function() { document.getElementById('confirmModal').classList.add('hidden'); document.getElementById('confirmModal').classList.remove('flex'); if (confirmResolve) { confirmResolve(true); confirmResolve = null; } });

async function changeRole(id, newRole) {
  var label = newRole === 'super_admin' ? 'Super Admin' : 'Admin';
  var ok = await showConfirm('Ubah role admin ini menjadi ' + label + '?', null, 'warning');
  if (!ok) return;
  try {
    var res = await fetch('/api/v1/admins/' + id + '/role', {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
      body: JSON.stringify({ role: newRole }),
    });
    var data = await res.json();
    if (data.success) { showToast('Role berhasil diubah', 'success'); setTimeout(function(){location.reload()},800); }
    else showToast(data.error || 'Gagal mengubah role', 'error');
  } catch (e) {
    showToast('Terjadi kesalahan: ' + e.message, 'error');
  }
}

async function deleteAdmin(id) {
  var ok = await showConfirm('Hapus admin ini?', 'Tindakan ini tidak bisa dibatalkan.', 'danger');
  if (!ok) return;
  try {
    var res = await fetch('/api/v1/admins/' + id, {
      method: 'DELETE',
      headers: { 'Authorization': 'Bearer ' + token },
    });
    var data = await res.json();
    if (data.success) { showToast('Admin berhasil dihapus', 'success'); setTimeout(function(){location.reload()},800); }
    else showToast(data.error || 'Gagal menghapus admin', 'error');
  } catch (e) {
    showToast('Terjadi kesalahan: ' + e.message, 'error');
  }
}
</script>
<%- include('../../partials/footer') %>