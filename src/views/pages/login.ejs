<%- include('../partials/header') %>
<div class="min-h-screen flex items-center justify-center px-4">
  <div class="w-full max-w-sm">
    <div class="text-center mb-8">
      <h1 class="text-2xl font-bold text-gray-900">Masuk ke <%= typeof settings !== 'undefined' && settings.site_name ? settings.site_name : 'AlumniLink' %></h1>
      <p class="text-gray-500 mt-2">Masukkan email dan password Anda</p>
    </div>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg text-sm mb-4"><%= error %></div>
    <% } %>

    <form action="/login" method="POST" class="space-y-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
        <input type="email" name="email" required class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" />
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Password</label>
        <div class="relative">
          <input type="password" name="password" id="passwordInput" required class="w-full px-3 py-2 pr-10 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" />
          <button type="button" onclick="togglePassword()" class="absolute right-2 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600 p-1">
            <span id="eyeIcon" class="material-symbols-outlined" style="font-size:20px">visibility</span>
          </button>
        </div>
      </div>
      <button type="submit" class="w-full py-2 bg-blue-600 text-white rounded-lg font-medium hover:bg-blue-700">Masuk</button>
    </form>

    <div class="text-center mt-6">
      <a href="/alumni" class="text-sm text-blue-600 hover:underline">&larr; Kembali ke beranda</a>
    </div>
  </div>
</div>
<script>
function togglePassword() {
  var input = document.getElementById('passwordInput');
  var icon = document.getElementById('eyeIcon');
  if (input.type === 'password') {
    input.type = 'text';
    icon.textContent = 'visibility_off';
  } else {
    input.type = 'password';
    icon.textContent = 'visibility';
  }
}
</script>
<%- include('../partials/footer') %>
