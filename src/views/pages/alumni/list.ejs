<%- include('../../partials/header') %>
<style>
  .soft-gradient { background: linear-gradient(135deg, var(--gradient-from), var(--gradient-to)); }
  .glass-card { background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(8px); border: 1px solid rgba(226, 232, 240, 0.5); }
  .card-hover:hover { transform: translateY(-4px); box-shadow: 0 12px 24px -10px rgba(0, 102, 255, 0.15); }
</style>
<div class="min-h-screen flex flex-col">
  <header class="w-full top-0 sticky z-50 bg-white shadow-sm border-b border-gray-200">
    <div class="flex items-center justify-between h-16 px-4 max-w-7xl mx-auto">
      <div class="flex items-center gap-2">
        <a href="/" class="text-xl font-bold" style="color: var(--brand-color)"><%= typeof settings !== 'undefined' && settings.site_name ? settings.site_name : 'AlumniLink' %></a>
      </div>
      <nav class="hidden md:flex items-center gap-6 text-sm">
        <a href="/alumni" class="text-blue-600 font-semibold border-b-2 border-blue-600 pb-1">Directory</a>
        <a href="/statistik" class="text-gray-500 hover:text-blue-600 transition-colors">Statistik</a>
        <a href="/alumni/baru" class="text-gray-500 hover:text-blue-600 transition-colors">Tambah Data</a>
      </nav>
      <div class="flex items-center gap-2">
        <% if (typeof user !== 'undefined' && user) { %>
          <a href="/dashboard" class="hidden md:inline-flex text-sm font-medium px-4 py-2 bg-gray-100 text-gray-700 rounded-lg hover:bg-gray-200">Dashboard</a>
          <a href="/logout" class="hidden md:inline-flex text-sm font-medium px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700">Keluar</a>
        <% } else { %>
          <a href="/login" class="hidden md:inline-flex text-sm font-medium px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700">Masuk</a>
        <% } %>
        <button id="menuBtn" class="md:hidden p-2 rounded-lg hover:bg-gray-100 transition-colors" onclick="toggleMenu()" aria-label="Menu">
          <span class="material-symbols-outlined">menu</span>
        </button>
      </div>
    </div>
  </header>
  <div class="md:hidden h-0.5" style="background: linear-gradient(135deg, var(--gradient-from), var(--gradient-to));"></div>

  <!-- Mobile menu -->
  <div id="mobileMenu" class="fixed inset-0 z-[60] hidden md:hidden">
    <div class="absolute inset-0 bg-black/40" onclick="toggleMenu()"></div>
    <div class="absolute right-0 top-0 h-full w-72 max-w-[85vw] bg-white shadow-2xl">
      <div class="flex items-center justify-between p-4 border-b border-gray-200">
        <span class="font-semibold text-gray-900">Menu</span>
        <button onclick="toggleMenu()" class="p-1 rounded-lg hover:bg-gray-100 transition-colors">
          <span class="material-symbols-outlined">close</span>
        </button>
      </div>
      <nav class="p-4 flex flex-col gap-1">
        <a href="/alumni" class="flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium bg-blue-50 text-blue-600">Directory</a>
        <a href="/statistik" class="flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-gray-600 hover:bg-gray-50">Statistik</a>
        <a href="/alumni/baru" class="flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-gray-600 hover:bg-gray-50">Tambah Data</a>
        <hr class="my-2 border-gray-200" />
        <% if (typeof user !== 'undefined' && user) { %>
          <a href="/dashboard" class="flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-gray-600 hover:bg-gray-50">Dashboard</a>
          <a href="/logout" class="flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-red-600 hover:bg-red-50">Keluar</a>
        <% } else { %>
          <a href="/login" class="flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-blue-600 hover:bg-blue-50">Masuk</a>
        <% } %>
      </nav>
    </div>
  </div>

  <section class="soft-gradient py-16 px-4 relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-0 left-0 w-64 h-64 bg-white rounded-full blur-3xl -translate-x-1/2 -translate-y-1/2"></div>
      <div class="absolute bottom-0 right-0 w-96 h-96 bg-white rounded-full blur-3xl translate-x-1/3 translate-y-1/3"></div>
    </div>
    <div class="max-w-7xl mx-auto relative z-10 text-center">
      <h1 class="text-4xl font-bold text-white mb-4">Daftar Alumni</h1>
      <p class="text-lg text-white/90 max-w-2xl mx-auto mb-8">Terhubung kembali dengan teman seangkatan dan bangun jejaring profesional di seluruh dunia.</p>
      <form method="GET" class="max-w-3xl mx-auto bg-white/10 backdrop-blur-md p-2 rounded-2xl border border-white/20 shadow-2xl">
        <div class="flex flex-col md:flex-row gap-2">
          <div class="flex-1 relative">
            <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-gray-400" style="font-size:20px">search</span>
            <input type="text" name="search" value="<%= typeof search !== 'undefined' ? search : '' %>" class="w-full pl-11 pr-4 py-3.5 rounded-xl border-0 focus:ring-2 focus:ring-white bg-white text-sm" placeholder="Cari nama, NIK, atau email..." />
          </div>
          <select name="province" class="px-4 py-3.5 rounded-xl border-0 bg-white text-sm focus:ring-2 focus:ring-white">
            <option value="">Semua Provinsi</option>
            <% if (typeof provinces !== 'undefined') { provinces.forEach(function(p) { %>
              <option value="<%= p %>" <%= typeof province !== 'undefined' && province === p ? 'selected' : '' %>><%= p %></option>
            <% }); } %>
          </select>
          <select name="careerStatus" class="px-4 py-3.5 rounded-xl border-0 bg-white text-sm focus:ring-2 focus:ring-white">
            <option value="">Semua Status</option>
            <% if (typeof careerStatuses !== 'undefined') { careerStatuses.forEach(function(s) { %>
              <option value="<%= s %>" <%= typeof careerStatus !== 'undefined' && careerStatus === s ? 'selected' : '' %>><%= s %></option>
            <% }); } %>
          </select>
          <button type="submit" class="px-6 py-3.5 bg-blue-600 text-white rounded-xl text-sm font-semibold hover:bg-blue-700 transition-all flex items-center gap-2">
            <span class="material-symbols-outlined" style="font-size:18px">search</span>Cari
          </button>
        </div>
      </form>
    </div>
  </section>

  <main class="flex-1 max-w-7xl mx-auto px-4 py-10 w-full">
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg text-sm mb-4"><%= error %></div>
    <% } %>

      <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3 mb-6">
        <h2 class="text-xl font-bold text-gray-900">Menampilkan <%= typeof alumni !== 'undefined' ? alumni.length : 0 %> Alumni</h2>
        <div class="flex flex-wrap items-center gap-2">
          <form method="GET" class="flex items-center gap-1.5 text-sm">
            <input type="hidden" name="search" value="<%= typeof search !== 'undefined' ? search : '' %>" />
            <input type="hidden" name="province" value="<%= typeof province !== 'undefined' ? province : '' %>" />
            <input type="hidden" name="careerStatus" value="<%= typeof careerStatus !== 'undefined' ? careerStatus : '' %>" />
            <label class="text-gray-500 text-xs">Tampil</label>
            <select name="limit" onchange="this.form.submit()" class="px-2 py-1.5 border border-gray-300 rounded-lg text-xs bg-white focus:ring-2 focus:ring-blue-500 outline-none">
              <% [5, 10, 20, 50, 100].forEach(function(n) { %>
                <option value="<%= n %>" <%= typeof limit !== 'undefined' && limit === n ? 'selected' : '' %>><%= n %></option>
              <% }); %>
            </select>
          </form>
          <a href="/alumni/baru" class="px-3 py-1.5 bg-blue-600 text-white rounded-lg text-xs font-medium hover:bg-blue-700 transition-all flex items-center gap-1">
            <span class="material-symbols-outlined" style="font-size:16px">add</span>Tambah Data
          </a>
          <div class="flex items-center gap-1 bg-gray-100 rounded-lg p-0.5">
            <button id="viewGrid" class="view-toggle p-1.5 rounded-md bg-white shadow-sm text-blue-600 transition-all" title="Tampilan Grid">
              <span class="material-symbols-outlined" style="font-size:18px">grid_view</span>
            </button>
            <button id="viewList" class="view-toggle p-1.5 rounded-md text-gray-400 hover:text-gray-600 transition-all" title="Tampilan Daftar">
              <span class="material-symbols-outlined" style="font-size:18px">view_list</span>
            </button>
          </div>
        </div>
      </div>

    <div id="alumniGridView" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5">
      <% if (typeof alumni !== 'undefined' && alumni.length) { alumni.forEach(function(a) { %>
        <a href="/alumni/<%= a.id %>" class="glass-card card-hover p-5 rounded-2xl transition-all duration-300 flex flex-col cursor-pointer bg-white/90">
          <div class="flex items-start gap-4 mb-4">
            <div class="w-12 h-12 rounded-full overflow-hidden border-2 border-blue-100 flex-shrink-0">
              <% if (a.photoUrl) { %>
                <img src="<%= a.photoUrl %>" class="w-full h-full object-cover" alt="" />
              <% } else { %>
                <div class="w-full h-full flex items-center justify-center text-white font-bold text-sm" style="background: linear-gradient(135deg, var(--gradient-from), var(--gradient-to));"><%= (a.name || '?').charAt(0).toUpperCase() %></div>
              <% } %>
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-bold text-gray-900 truncate"><%= a.name %></h3>
              <p class="text-xs text-blue-600 font-semibold truncate"><%= a.position || a.careerStatus || '' %></p>
              <p class="text-xs text-gray-500 truncate"><%= a.institutionName || '' %></p>
            </div>
          </div>
          <div class="space-y-1.5 mb-3 flex-1">
            <div class="flex items-center gap-1.5 text-gray-500">
              <span class="material-symbols-outlined" style="font-size:14px"><%= a.gender === 'Laki-laki' ? 'male' : 'female' %></span>
              <span class="text-xs"><%= a.gender || '-' %></span>
            </div>
            <div class="flex items-center gap-1.5 text-gray-500">
              <span class="material-symbols-outlined" style="font-size:14px">location_on</span>
              <span class="text-xs truncate"><%= a.province || '-' %></span>
            </div>
          </div>
          <div class="border-t border-gray-100 pt-3 mt-auto flex items-center justify-between">
            <span class="text-xs text-gray-500"><%= a.careerStatus || '-' %></span>
            <span class="text-blue-600 text-xs font-medium flex items-center gap-1">Detail <span class="material-symbols-outlined" style="font-size:14px">arrow_forward</span></span>
          </div>
        </a>
      <% }); } %>
    </div>

    <div id="alumniListView" class="hidden space-y-2">
      <% if (typeof alumni !== 'undefined' && alumni.length) { alumni.forEach(function(a) { %>
        <a href="/alumni/<%= a.id %>" class="glass-card flex items-center gap-4 p-4 rounded-xl transition-all duration-200 hover:bg-white hover:shadow-md cursor-pointer bg-white/90">
          <div class="w-10 h-10 rounded-full overflow-hidden border-2 border-blue-100 flex-shrink-0">
            <% if (a.photoUrl) { %>
              <img src="<%= a.photoUrl %>" class="w-full h-full object-cover" alt="" />
            <% } else { %>
              <div class="w-full h-full flex items-center justify-center text-white font-bold text-xs" style="background: linear-gradient(135deg, var(--gradient-from), var(--gradient-to));"><%= (a.name || '?').charAt(0).toUpperCase() %></div>
            <% } %>
          </div>
          <div class="flex-1 min-w-0 grid grid-cols-1 md:grid-cols-4 gap-2 md:gap-4 items-center">
            <div class="min-w-0">
              <p class="text-sm font-semibold text-gray-900 truncate"><%= a.name %></p>
              <p class="text-xs text-blue-600 truncate"><%= a.position || a.careerStatus || '' %></p>
            </div>
            <p class="text-xs text-gray-500 truncate hidden md:block"><%= a.institutionName || '-' %></p>
            <p class="text-xs text-gray-500 truncate hidden md:block"><%= a.province || '-' %></p>
            <div class="text-right hidden md:block">
              <span class="inline-flex px-2.5 py-1 rounded-full text-xs font-medium <%= a.careerStatus === 'Pekerja' ? 'bg-blue-100 text-blue-700' : a.careerStatus === 'Wirausaha' ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-600' %>"><%= a.careerStatus || '-' %></span>
            </div>
          </div>
          <span class="material-symbols-outlined text-gray-400 flex-shrink-0" style="font-size:18px">chevron_right</span>
        </a>
      <% }); } %>
    </div>

    <% if (typeof alumni === 'undefined' || !alumni.length) { %>
      <div class="text-center py-16 text-gray-400">
        <span class="material-symbols-outlined text-4xl mb-3 block">people_outline</span>
        <p class="text-base">Belum ada data alumni</p>
      </div>
    <% } %>

    <% if (typeof totalPages !== 'undefined' && totalPages > 1) { %>
      <div class="flex items-center justify-center gap-2 mt-10">
        <% if (page > 1) { %>
          <a href="?page=<%= page - 1 %>&limit=<%= limit %><%= search ? '&search=' + search : '' %><%= province ? '&province=' + province : '' %><%= careerStatus ? '&careerStatus=' + careerStatus : '' %>" class="p-2 rounded-lg border border-gray-300 text-gray-500 hover:bg-gray-100 transition-colors"><span class="material-symbols-outlined" style="font-size:18px">chevron_left</span></a>
        <% } %>
        <% for (var p = Math.max(1, page - 2); p <= Math.min(totalPages, page + 2); p++) { %>
          <a href="?page=<%= p %>&limit=<%= limit %><%= search ? '&search=' + search : '' %><%= province ? '&province=' + province : '' %><%= careerStatus ? '&careerStatus=' + careerStatus : '' %>" class="w-10 h-10 rounded-lg flex items-center justify-center text-sm font-medium <%= p === page ? 'bg-blue-600 text-white' : 'text-gray-500 hover:bg-gray-100' %>"><%= p %></a>
        <% } %>
        <% if (page < totalPages) { %>
          <a href="?page=<%= page + 1 %>&limit=<%= limit %><%= search ? '&search=' + search : '' %><%= province ? '&province=' + province : '' %><%= careerStatus ? '&careerStatus=' + careerStatus : '' %>" class="p-2 rounded-lg border border-gray-300 text-gray-500 hover:bg-gray-100 transition-colors"><span class="material-symbols-outlined" style="font-size:18px">chevron_right</span></a>
        <% } %>
      </div>
    <% } %>
  </main>
</div>
<script>
function toggleMenu() {
  var menu = document.getElementById('mobileMenu');
  menu.classList.toggle('hidden');
  document.body.classList.toggle('overflow-hidden');
}

(function() {
  var gridBtn = document.getElementById('viewGrid');
  var listBtn = document.getElementById('viewList');
  var gridView = document.getElementById('alumniGridView');
  var listView = document.getElementById('alumniListView');

  var view = localStorage.getItem('alumniView') || 'grid';

  function setView(v) {
    view = v;
    localStorage.setItem('alumniView', v);
    if (v === 'list') {
      gridView.classList.add('hidden');
      listView.classList.remove('hidden');
      gridBtn.classList.remove('bg-white', 'shadow-sm', 'text-blue-600');
      gridBtn.classList.add('text-gray-400');
      listBtn.classList.add('bg-white', 'shadow-sm', 'text-blue-600');
      listBtn.classList.remove('text-gray-400');
    } else {
      gridView.classList.remove('hidden');
      listView.classList.add('hidden');
      listBtn.classList.remove('bg-white', 'shadow-sm', 'text-blue-600');
      listBtn.classList.add('text-gray-400');
      gridBtn.classList.add('bg-white', 'shadow-sm', 'text-blue-600');
      gridBtn.classList.remove('text-gray-400');
    }
  }

  gridBtn.addEventListener('click', function() { setView('grid'); });
  listBtn.addEventListener('click', function() { setView('list'); });

  setView(view);
})();
</script>
<%- include('../../partials/footer') %>
