  // --- Photo upload helper ---
  function uploadPhoto(file) {
    return new Promise(function(resolve, reject) {
      var fd = new FormData();
      fd.append('file', file);
      fetch('/api/v1/upload/alumni-photo', {
        method: 'POST',
        headers: token ? { Authorization: 'Bearer ' + token } : {},
        body: fd,
      })
        .then(function(res) {
          if (!res.ok) return res.json().then(function(d) { throw new Error(d.error || 'Gagal upload foto'); });
          return res.json();
        })
        .then(function(data) { resolve(data.data.url); })
        .catch(reject);
    });
  }

  // --- Submit ---
  document.getElementById('alumniForm').addEventListener('submit', function(e) {
    e.preventDefault();

    var nikEl = document.getElementById('nik');
    var nikVal = nikEl ? nikEl.value.trim() : '';
    if (!nikVal) { showFormMessage('NIK wajib diisi', 'error'); return; }
    if (!/^\d{16}$/.test(nikVal)) { showFormMessage('NIK harus 16 digit angka', 'error'); return; }

    var requiredFields = {
      name: 'Nama Lengkap',
      gender: 'Jenis Kelamin',
      maritalStatus: 'Status Pernikahan',
      phone: 'No. HP/WhatsApp',
      email: 'Email Aktif',
      provinceCode: 'Provinsi',
      careerStatus: 'Status Pekerjaan',
    };
    var missingFields = [];
    for (var key in requiredFields) {
      var el = document.getElementById(key) || document.querySelector('[name="' + key + '"]');
      if (!el || !el.value.trim()) missingFields.push(requiredFields[key]);
    }
    if (missingFields.length) {
      showFormMessage('Field wajib diisi: ' + missingFields.join(', '), 'error');
      return;
    }

    var btn = this.querySelector('button[type="submit"]');
    btn.disabled = true;
    btn.innerHTML = '<span class="material-symbols-outlined animate-spin">refresh</span> Mengirim...';

    // Education
    var eduData = [];
    document.querySelectorAll('#educationContainer > div').forEach(function(row) {
      eduData.push({
        level: row.querySelector('[name="eduLevel"]')?.value || '',
        countryCode: row.querySelector('[name="eduCountry"]')?.value || '',
        university: row.querySelector('[name="eduUniversity"]')?.value || '',
        faculty: row.querySelector('[name="eduFaculty"]')?.value || '',
        major: row.querySelector('[name="eduMajor"]')?.value || '',
        graduationYear: parseInt(row.querySelector('[name="eduGradYear"]')?.value) || null,
      });
    });

    // Certificates
    var certData = [];
    document.querySelectorAll('#certificateContainer > div').forEach(function(row) {
      certData.push({
        name: row.querySelector('[name="certName"]')?.value || '',
        publisher: row.querySelector('[name="certPublisher"]')?.value || '',
        validUntil: row.querySelector('[name="certValidUntil"]')?.value || '',
      });
    });

    // Organizations
    var orgData = [];
    document.querySelectorAll('#organizationContainer > div').forEach(function(row) {
      orgData.push({
        name: row.querySelector('[name="orgName"]')?.value || '',
        type: row.querySelector('[name="orgType"]')?.value || '',
        level: row.querySelector('[name="orgLevel"]')?.value || '',
        position: row.querySelector('[name="orgPosition"]')?.value || '',
        field: row.querySelector('[name="orgField"]')?.value || '',
      });
    });

    // Portfolios
    var portData = [];
    document.querySelectorAll('#portfolioContainer > div').forEach(function(row) {
      portData.push({
        name: row.querySelector('[name="portName"]')?.value || '',
        type: row.querySelector('[name="portType"]')?.value || '',
        typeOther: row.querySelector('[name="portTypeOther"]')?.value || '',
        year: parseInt(row.querySelector('[name="portYear"]')?.value) || null,
        link: row.querySelector('[name="portLink"]')?.value || '',
      });
    });

    // Businesses
    var bizData = [];
    document.querySelectorAll('#businessContainer > div').forEach(function(row) {
      var productsStr = row.querySelector('[name="bizProducts"]')?.value || '';
      bizData.push({
        legalForm: row.querySelector('[name="bizLegalForm"]')?.value || '',
        name: row.querySelector('[name="bizName"]')?.value || '',
        field: row.querySelector('[name="bizField"]')?.value || '',
        scale: row.querySelector('[name="bizScale"]')?.value || '',
        businessModel: row.querySelector('[name="bizModel"]')?.value || '',
        products: productsStr,
        website: row.querySelector('[name="bizWebsite"]')?.value || '',
        companyProfile: row.querySelector('[name="bizProfile"]')?.value || '',
      });
    });

    // Social links
    var socialRaw = JSON.parse(document.getElementById('socialLinks').value || '[]');
    var socialLinksArr = socialRaw.map(function(s) { return { url: s }; });

    function doSubmit(photoUrl) {
      var body = {
        name: document.getElementById('name').value.trim(),
        nik: document.getElementById('nik').value.trim() || undefined,
        gender: document.querySelector('input[name="gender"]:checked')?.value || undefined,
        maritalStatus: document.getElementById('maritalStatus').value || undefined,
        phone: document.getElementById('phone').value.trim() || undefined,
        email: document.getElementById('email').value.trim() || undefined,
        address: document.getElementById('address').value.trim() || undefined,
        province: document.getElementById('provinceName').value || undefined,
        provinceCode: document.getElementById('provinceCode').value || undefined,
        regencyCode: document.getElementById('regencyCode').value || undefined,
        regencyName: document.getElementById('regencyName').value || undefined,
        districtCode: document.getElementById('districtCode').value || undefined,
        districtName: document.getElementById('districtName').value || undefined,
        villageCode: document.getElementById('villageCode').value || undefined,
        villageName: document.getElementById('villageName').value || undefined,
        careerStatus: document.getElementById('careerStatus').value || undefined,
        careerOther: document.getElementById('careerOther').value.trim() || undefined,
        institutionName: document.getElementById('institutionName').value.trim() || undefined,
        institutionField: document.getElementById('institutionField').value.trim() || undefined,
        position: document.getElementById('position').value.trim() || undefined,
        photoUrl: photoUrl || undefined,
        education: eduData.length ? eduData : undefined,
        certificates: certData.length ? certData : undefined,
        organizations: orgData.length ? orgData : undefined,
        portfolios: portData.length ? portData : undefined,
        businesses: bizData.length ? bizData : undefined,
        socialLinks: socialLinksArr.length ? socialLinksArr : undefined,
      };

      var headers = { 'Content-Type': 'application/json' };
      if (token) headers['Authorization'] = 'Bearer ' + token;

      fetch('/api/v1/alumni', { method: 'POST', headers: headers, body: JSON.stringify(body) })
        .then(function(r) { return r.json(); })
        .then(function(res) {
          btn.disabled = false;
          btn.innerHTML = '<span class="material-symbols-outlined">send</span>Kirim Data';
          if (res.success) {
            if (token) {
              window.location.href = '/dashboard/alumni';
            } else {
              window.location.href = '/alumni';
            }
          } else {
            showFormMessage(res.error || 'Gagal mengirim data', 'error');
          }
        })
        .catch(function(err) {
          btn.disabled = false;
          btn.innerHTML = '<span class="material-symbols-outlined">send</span>Kirim Data';
          showFormMessage('Terjadi kesalahan: ' + err.message, 'error');
        });
    }

    var photoFile = document.getElementById('photo').files[0];
    if (photoFile) {
      uploadPhoto(photoFile).then(doSubmit).catch(function(err) {
        btn.disabled = false;
        btn.innerHTML = '<span class="material-symbols-outlined">send</span>Kirim Data';
        showFormMessage(err.message, 'error');
      });
    } else {
      doSubmit(null);
    }
  });
})();
</script>
<%- include('../../partials/footer') %>
