<%- include('../../partials/header') %>
<style>
  .soft-gradient { background: linear-gradient(135deg, var(--gradient-from), var(--gradient-to)); }
  .glass-card { background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(8px); border: 1px solid rgba(226, 232, 240, 0.5); }
  .toast-enter { animation: toastIn 0.3s ease-out; }
  .toast-leave { animation: toastOut 0.3s ease-in forwards; }
  @keyframes toastIn { from { transform: translateX(100%); opacity: 0; } to { transform: translateX(0); opacity: 1; } }
  @keyframes toastOut { from { transform: translateX(0); opacity: 1; } to { transform: translateX(100%); opacity: 0; } }
</style>
<div id="toastContainer" class="fixed top-4 right-4 z-[100] flex flex-col gap-2 pointer-events-none" style="min-width:320px;max-width:420px"></div>
<div class="min-h-screen flex flex-col">
  <header class="w-full top-0 sticky z-50 bg-white shadow-sm border-b border-gray-200">
    <div class="flex items-center justify-between h-16 px-4 max-w-4xl mx-auto">
      <div class="flex items-center gap-2">
        <a href="/" class="text-xl font-bold" style="color: var(--brand-color)"><%= typeof settings !== 'undefined' && settings.site_name ? settings.site_name : 'AlumniLink' %></a>
        <a href="/statistik" class="md:hidden text-xs text-blue-600 hover:underline">Statistik</a>
      </div>
      <nav class="hidden md:flex items-center gap-6 text-sm">
        <a href="/alumni" class="text-gray-500 hover:text-blue-600 transition-colors">Directory</a>
        <a href="/statistik" class="text-gray-500 hover:text-blue-600 transition-colors">Statistik</a>
        <a href="/alumni/baru" class="text-blue-600 font-semibold border-b-2 border-blue-600 pb-1">Tambah Data</a>
      </nav>
      <div class="flex items-center gap-3">
        <% if (typeof user !== 'undefined' && user) { %>
          <a href="/dashboard" class="text-sm font-medium px-4 py-2 bg-gray-100 text-gray-700 rounded-lg hover:bg-gray-200">Dashboard</a>
          <a href="/logout" class="text-sm font-medium px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700">Keluar</a>
        <% } else { %>
          <a href="/login" class="text-sm font-medium px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700">Masuk</a>
        <% } %>
      </div>
    </div>
  </header>

  <section class="soft-gradient py-12 px-4 relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-0 left-0 w-64 h-64 bg-white rounded-full blur-3xl -translate-x-1/2 -translate-y-1/2"></div>
      <div class="absolute bottom-0 right-0 w-96 h-96 bg-white rounded-full blur-3xl translate-x-1/3 translate-y-1/3"></div>
    </div>
    <div class="max-w-4xl mx-auto relative z-10 text-center">
      <h1 class="text-3xl font-bold text-white mb-2">Tambah Data Alumni</h1>
      <p class="text-white/80">Isi data diri Anda. Data akan ditinjau admin sebelum ditampilkan di directory.</p>
    </div>
  </section>

  <main class="flex-1 max-w-4xl mx-auto px-4 py-8 w-full">
    <a href="/alumni" class="text-sm text-blue-600 hover:underline mb-4 inline-block">&larr; Kembali ke directory</a>

    <form id="alumniForm" action="/alumni/baru" method="POST" class="space-y-6">
      <div id="formMessage" class="<%= error ? 'p-4 rounded-lg text-sm bg-red-50 border border-red-200 text-red-700' : 'hidden' %>"><%= error || '' %></div>

      <!-- SECTION 1: Data Pribadi -->
      <div class="glass-card rounded-2xl p-6 shadow-sm border border-gray-200/50 bg-white/90">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-lg bg-blue-100 flex items-center justify-center">
            <span class="material-symbols-outlined text-blue-600">badge</span>
          </div>
          <h2 class="text-lg font-semibold">Data Pribadi</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          <div>
            <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1.5" for="nik">NIK <span class="text-red-500">*</span></label>
            <input class="w-full px-4 py-2.5 rounded-xl border border-gray-300 bg-white text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" id="nik" name="nik" placeholder="16 digit NIK" required type="text" maxlength="16" />
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1.5" for="name">Nama Lengkap <span class="text-red-500">*</span></label>
            <input class="w-full px-4 py-2.5 rounded-xl border border-gray-300 bg-white text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" id="name" name="name" placeholder="Nama lengkap sesuai KTP" required type="text" />
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1.5">Jenis Kelamin <span class="text-red-500">*</span></label>
            <div class="flex gap-4 pt-1.5">
              <label class="flex items-center gap-2 cursor-pointer text-sm"><input class="w-4 h-4 text-blue-600" name="gender" required type="radio" value="Laki-laki" /><span>Laki-laki</span></label>
              <label class="flex items-center gap-2 cursor-pointer text-sm"><input class="w-4 h-4 text-blue-600" name="gender" type="radio" value="Perempuan" /><span>Perempuan</span></label>
            </div>
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1.5" for="maritalStatus">Status Pernikahan <span class="text-red-500">*</span></label>
            <select class="w-full px-4 py-2.5 rounded-xl border border-gray-300 bg-white text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" id="maritalStatus" name="maritalStatus" required>
              <option value="">Pilih status</option>
              <option value="Belum Menikah">Belum Menikah</option>
              <option value="Menikah">Menikah</option>
              <option value="Pernah Menikah (Duda/Janda)">Pernah Menikah (Duda/Janda)</option>
            </select>
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1.5" for="phone">No. HP/WhatsApp <span class="text-red-500">*</span></label>
            <input class="w-full px-4 py-2.5 rounded-xl border border-gray-300 bg-white text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" id="phone" name="phone" placeholder="+62 812-3456-7890" required type="tel" />
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1.5" for="email">Email Aktif <span class="text-red-500">*</span></label>
            <input class="w-full px-4 py-2.5 rounded-xl border border-gray-300 bg-white text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" id="email" name="email" placeholder="nama@email.com" required type="email" />
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1.5">Link Media Sosial</label>
            <div class="flex gap-2 mb-2">
              <input class="flex-1 px-4 py-2.5 rounded-xl border border-gray-300 bg-white text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" id="socialLinkInput" placeholder="https://linkedin.com/in/username" type="url" />
              <button class="px-4 py-2.5 bg-gray-100 text-gray-700 rounded-xl text-sm font-medium hover:bg-gray-200 transition-all" id="addSocialBtn" type="button">Tambah</button>
            </div>
            <div class="flex flex-wrap gap-1.5" id="socialLinksContainer"></div>
            <input id="socialLinks" name="socialLinks" type="hidden" />
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1.5" for="photo">Foto</label>
            <input class="w-full px-4 py-2.5 rounded-xl border border-gray-300 bg-white text-sm file:mr-3 file:py-1.5 file:px-3 file:rounded-lg file:border-0 file:bg-blue-100 file:text-blue-700 file:text-xs file:font-semibold" id="photo" name="photo" accept="image/*" type="file" />
            <p class="text-xs text-gray-400 mt-1">Format: JPEG, PNG, GIF, WebP. Maksimal <%= typeof maxFileSizeKb !== 'undefined' && maxFileSizeKb ? maxFileSizeKb : 500 %>KB.</p>
            <div id="photoPreview" class="mt-2 hidden">
              <img class="w-20 h-20 rounded-xl object-cover border border-gray-300" id="photoPreviewImg" alt="Preview" />
              <button type="button" id="removePhotoBtn" class="mt-1.5 text-xs text-red-600 hover:text-red-700 font-medium hidden">Hapus Foto</button>
            </div>
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1.5">Provinsi <span class="text-red-500">*</span></label>
            <select class="w-full px-4 py-2.5 rounded-xl border border-gray-300 bg-white text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" id="provinceCode" required>
              <option value="">Pilih provinsi</option>
            </select>
            <input id="provinceName" name="province" type="hidden" />
            <input id="regencyName" name="regencyName" type="hidden" />
            <input id="districtName" name="districtName" type="hidden" />
            <input id="villageName" name="villageName" type="hidden" />
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1.5">Kabupaten</label>
            <select class="w-full px-4 py-2.5 rounded-xl border border-gray-300 bg-white text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" id="regencyCode">
              <option value="">Pilih kabupaten</option>
            </select>
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1.5">Kecamatan</label>
            <select class="w-full px-4 py-2.5 rounded-xl border border-gray-300 bg-white text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" id="districtCode">
              <option value="">Pilih kecamatan</option>
            </select>
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1.5">Kelurahan</label>
            <select class="w-full px-4 py-2.5 rounded-xl border border-gray-300 bg-white text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" id="villageCode">
              <option value="">Pilih kelurahan</option>
            </select>
          </div>
          <div class="md:col-span-2">
            <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1.5" for="address">Alamat Domisili Lengkap <span class="text-red-500">*</span></label>
            <textarea class="w-full px-4 py-2.5 rounded-xl border border-gray-300 bg-white text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none resize-none" id="address" name="address" placeholder="RT/RW, Kelurahan, Kecamatan, Kota/Kabupaten, Kode Pos" rows="3"></textarea>
          </div>
        </div>
      </div>

      <!-- SECTION 2: Pendidikan -->
      <div class="glass-card rounded-2xl p-6 shadow-sm border border-gray-200/50 bg-white/90">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-lg bg-blue-100 flex items-center justify-center">
            <span class="material-symbols-outlined text-blue-600">school</span>
          </div>
          <h2 class="text-lg font-semibold">Latar Belakang Pendidikan</h2>
        </div>
        <p class="text-sm text-gray-500 mb-4">Tambahkan riwayat pendidikan dari jenjang S1 sampai S3</p>
        <div id="educationContainer" class="space-y-4"></div>
        <button class="mt-3 px-6 py-2.5 border-2 border-dashed border-gray-300 rounded-xl text-gray-500 text-sm font-medium hover:bg-gray-50 hover:border-blue-400 transition-all w-full flex items-center justify-center gap-2" id="addEducationBtn" type="button">
          <span class="material-symbols-outlined">add</span>Tambah Riwayat Pendidikan
        </button>
      </div>

      <!-- SECTION 3: Sertifikat -->
      <div class="glass-card rounded-2xl p-6 shadow-sm border border-gray-200/50 bg-white/90">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-lg bg-blue-100 flex items-center justify-center">
            <span class="material-symbols-outlined text-blue-600">verified</span>
          </div>
          <h2 class="text-lg font-semibold">Sertifikat Kompetensi</h2>
        </div>
        <div id="certificateContainer" class="space-y-4"></div>
        <button class="mt-3 px-6 py-2.5 border-2 border-dashed border-gray-300 rounded-xl text-gray-500 text-sm font-medium hover:bg-gray-50 hover:border-blue-400 transition-all w-full flex items-center justify-center gap-2" id="addCertificateBtn" type="button">
          <span class="material-symbols-outlined">add</span>Tambah Sertifikat
        </button>
      </div>

      <!-- SECTION 4: Organisasi -->
      <div class="glass-card rounded-2xl p-6 shadow-sm border border-gray-200/50 bg-white/90">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-lg bg-blue-100 flex items-center justify-center">
            <span class="material-symbols-outlined text-blue-600">groups</span>
          </div>
          <h2 class="text-lg font-semibold">Pengalaman Organisasi</h2>
        </div>
        <div id="organizationContainer" class="space-y-4"></div>
        <button class="mt-3 px-6 py-2.5 border-2 border-dashed border-gray-300 rounded-xl text-gray-500 text-sm font-medium hover:bg-gray-50 hover:border-blue-400 transition-all w-full flex items-center justify-center gap-2" id="addOrgBtn" type="button">
          <span class="material-symbols-outlined">add</span>Tambah Pengalaman Organisasi
        </button>
      </div>

      <!-- SECTION 4.5: Portfolio -->
      <div class="glass-card rounded-2xl p-6 shadow-sm border border-gray-200/50 bg-white/90">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-lg bg-blue-100 flex items-center justify-center">
            <span class="material-symbols-outlined text-blue-600">folder</span>
          </div>
          <h2 class="text-lg font-semibold">Portofolio</h2>
        </div>
        <p class="text-sm text-gray-500 mb-4">Tambahkan portofolio karya (buku, aplikasi, website, dll)</p>
        <div id="portfolioContainer" class="space-y-4"></div>
        <button class="mt-3 px-6 py-2.5 border-2 border-dashed border-gray-300 rounded-xl text-gray-500 text-sm font-medium hover:bg-gray-50 hover:border-blue-400 transition-all w-full flex items-center justify-center gap-2" id="addPortfolioBtn" type="button">
          <span class="material-symbols-outlined">add</span>Tambah Portofolio
        </button>
      </div>

      <!-- SECTION 5: Karir -->
      <div class="glass-card rounded-2xl p-6 shadow-sm border border-gray-200/50 bg-white/90">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-lg bg-blue-100 flex items-center justify-center">
            <span class="material-symbols-outlined text-blue-600">work</span>
          </div>
          <h2 class="text-lg font-semibold">Profil Pekerjaan / Karir</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          <div>
            <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1.5" for="careerStatus">Status Pekerjaan Saat Ini <span class="text-red-500">*</span></label>
            <select class="w-full px-4 py-2.5 rounded-xl border border-gray-300 bg-white text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" id="careerStatus" name="careerStatus" required>
              <option value="">Pilih status</option>
              <option value="Pekerja">Pekerja</option>
              <option value="Wirausaha">Wirausaha</option>
              <option value="Profesional">Profesional (Pengacara, Dokter, Insinyur, Konsultan, dll)</option>
              <option value="Tenaga Pendidik">Tenaga Pendidik</option>
              <option value="Pencari Kerja">Pencari Kerja</option>
              <option value="Lainnya">Lainnya</option>
            </select>
          </div>
          <div id="careerOtherWrapper" class="hidden">
            <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1.5" for="careerOther">Sebutkan <span class="text-red-500">*</span></label>
            <input class="w-full px-4 py-2.5 rounded-xl border border-gray-300 bg-white text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" id="careerOther" name="careerOther" placeholder="Jabatan/profesi lainnya" type="text" />
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1.5" for="institutionName">Nama Instansi/Perusahaan</label>
            <input class="w-full px-4 py-2.5 rounded-xl border border-gray-300 bg-white text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" id="institutionName" name="institutionName" placeholder="Nama perusahaan/instansi" type="text" />
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1.5" for="institutionField">Bidang Instansi/Perusahaan</label>
            <input class="w-full px-4 py-2.5 rounded-xl border border-gray-300 bg-white text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" id="institutionField" name="institutionField" placeholder="Contoh: Teknologi Informasi" type="text" />
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1.5" for="position">Jabatan</label>
            <input class="w-full px-4 py-2.5 rounded-xl border border-gray-300 bg-white text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" id="position" name="position" placeholder="Contoh: Senior Software Engineer" type="text" />
          </div>
        </div>
      </div>

      <!-- SECTION 6: Usaha -->
      <div class="glass-card rounded-2xl p-6 shadow-sm border border-gray-200/50 bg-white/90">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-lg bg-blue-100 flex items-center justify-center">
            <span class="material-symbols-outlined text-blue-600">store</span>
          </div>
          <h2 class="text-lg font-semibold">Data Usaha</h2>
        </div>
        <p class="text-sm text-gray-500 mb-4">Isi jika memiliki usaha (bisa lebih dari satu)</p>
        <div id="businessContainer" class="space-y-4"></div>
        <button class="mt-3 px-6 py-2.5 border-2 border-dashed border-gray-300 rounded-xl text-gray-500 text-sm font-medium hover:bg-gray-50 hover:border-blue-400 transition-all w-full flex items-center justify-center gap-2" id="addBusinessBtn" type="button">
          <span class="material-symbols-outlined">add</span>Tambah Data Usaha
        </button>
      </div>

      <!-- Submit -->
      <div class="flex flex-col md:flex-row gap-4">
        <button class="flex-1 bg-blue-600 text-white py-3 px-6 rounded-xl font-semibold text-sm hover:bg-blue-700 transition-all shadow-lg shadow-blue-600/20 flex items-center justify-center gap-2" type="submit">
          <span class="material-symbols-outlined">send</span>Kirim Data
        </button>
        <a class="flex-1 bg-gray-200 text-gray-700 py-3 px-6 rounded-xl font-semibold text-sm hover:bg-gray-300 transition-all flex items-center justify-center gap-2" href="/alumni">
          <span class="material-symbols-outlined">cancel</span>Batal
        </a>
      </div>
    </form>
  </main>
</div>

<script id="authData" type="application/json"><%- JSON.stringify(typeof token !== 'undefined' ? token : '') %></script>
<script>
(function() {
  var token = JSON.parse(document.getElementById('authData').textContent);

  // --- Toast ---
  function showToast(message, type) {
    type = type || 'info';
    var colors = {
      success: { bg: 'bg-green-50', border: 'border-green-200', text: 'text-green-800', icon: 'check_circle', iconBg: 'bg-green-100', iconColor: 'text-green-600' },
      error:   { bg: 'bg-red-50',    border: 'border-red-200',   text: 'text-red-800',   icon: 'error',         iconBg: 'bg-red-100',   iconColor: 'text-red-600' },
      warning: { bg: 'bg-yellow-50', border: 'border-yellow-200', text: 'text-yellow-800', icon: 'warning',       iconBg: 'bg-yellow-100', iconColor: 'text-yellow-600' },
      info:    { bg: 'bg-blue-50',   border: 'border-blue-200',  text: 'text-blue-800',  icon: 'info',          iconBg: 'bg-blue-100',  iconColor: 'text-blue-600' },
    };
    var c = colors[type] || colors.info;
    var container = document.getElementById('toastContainer');
    var el = document.createElement('div');
    el.className = 'pointer-events-auto toast-enter ' + c.bg + ' ' + c.border + ' border rounded-xl shadow-lg px-4 py-3 flex items-start gap-3';
    el.innerHTML =
      '<div class="w-8 h-8 rounded-full ' + c.iconBg + ' flex items-center justify-center flex-shrink-0">' +
        '<span class="material-symbols-outlined ' + c.iconColor + '" style="font-size:18px">' + c.icon + '</span>' +
      '</div>' +
      '<p class="text-sm ' + c.text + ' flex-1 pt-0.5">' + escapeHtml(message) + '</p>' +
      '<button onclick="this.closest(\'div\').classList.add(\'toast-leave\');setTimeout(function(){this.closest(\'div\').remove()}.bind(this),300)" class="flex-shrink-0 ' + c.text + ' hover:opacity-70">' +
        '<span class="material-symbols-outlined" style="font-size:16px">close</span>' +
      '</button>';
    container.appendChild(el);
    setTimeout(function() {
      if (el.parentNode) { el.classList.add('toast-leave'); setTimeout(function() { if (el.parentNode) el.remove(); }, 300); }
    }, 4000);
  }

  function escapeHtml(str) {
    var d = document.createElement('div'); d.textContent = str; return d.innerHTML;
  }

  // --- Form message ---
  function showFormMessage(msg, type) {
    var el = document.getElementById('formMessage');
    el.className = 'p-4 rounded-lg text-sm ' + (type === 'error' ? 'bg-red-50 border border-red-200 text-red-700' : 'bg-green-50 border border-green-200 text-green-700');
    el.textContent = msg;
    el.classList.remove('hidden');
  }

  // --- Wilayah cascading dropdowns ---
  function loadWilayah(parentCode, targetSelect, keepValue) {
    var url = '/api/v1/wilayah' + (parentCode ? '?parent=' + parentCode : '');
    return fetch(url)
      .then(function(r) { return r.json(); })
      .then(function(res) {
        if (!res.success) return;
        var data = res.data || [];
        targetSelect.innerHTML = '<option value="">' + targetSelect.dataset.placeholder + '</option>';
        data.forEach(function(w) {
          var o = document.createElement('option');
          o.value = w.kode;
          o.textContent = w.nama;
          if (keepValue && w.kode === keepValue) o.selected = true;
          targetSelect.appendChild(o);
        });
        return data;
      });
  }

  var selProv = document.getElementById('provinceCode');
  var selReg = document.getElementById('regencyCode');
  var selDist = document.getElementById('districtCode');
  var selVill = document.getElementById('villageCode');
  selProv.dataset.placeholder = 'Pilih provinsi';
  selReg.dataset.placeholder = 'Pilih kabupaten';
  selDist.dataset.placeholder = 'Pilih kecamatan';
