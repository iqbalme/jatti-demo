# ── Database ──
# PostgreSQL (default) — langsung jalan
DATABASE_URL=postgresql://postgres:password@localhost:5432/nama_database
# MySQL — tinggal ganti URL, sisanya otomatis
# DATABASE_URL=mysql://root:password@localhost:3306/nama_database

# ── Authentication ──
# "supabase" (default) — login via Supabase Auth, wajib isi NEXT_PUBLIC_SUPABASE_*
# "local" — login diverifikasi langsung ke database, tidak perlu Supabase Auth
AUTH_PROVIDER=supabase
# JWT_SECRET hanya diperlukan untuk AUTH_PROVIDER=local (fallback ke SUPABASE_JWT_SECRET)
# JWT_SECRET=your-random-secret-key

# ── Supabase (wajib diisi jika AUTH_PROVIDER=supabase) ──
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# ── Storage ──
# Pilih penyimpanan file: "supabase" (default) atau "local"
STORAGE_PROVIDER=supabase
UPLOAD_DIR=public/uploads
UPLOAD_MAX_FILE_SIZE_KB=500
SUPABASE_STORAGE_BUCKET=alumni-photos

# ── App ──
PORT=3000
NODE_ENV=development

# ── Super Admin ──
SUPER_ADMIN_EMAIL=superadmin@example.com
SUPER_ADMIN_PASSWORD=your-super-admin-password
