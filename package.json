{
  "name": "alumnilink",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && node -e \"require('fs').cpSync('src/views','dist/views',{recursive:true})\"",
    "start": "node dist/index.js",
    "vercel-build": "prisma generate && tsc && node -e \"require('fs').cpSync('src/views','dist/views',{recursive:true})\"",
    "db:detect": "node scripts/detect-provider.mjs",
    "db:generate": "node scripts/detect-provider.mjs && prisma generate",
    "db:migrate": "node scripts/detect-provider.mjs && prisma migrate dev",
    "db:seed": "tsx src/database/seed.ts",
"db:seed-countries": "tsx src/database/seed-countries.ts",
    "db:studio": "prisma studio",
    "db:push": "node scripts/detect-provider.mjs && prisma db push",
    "lint": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@prisma/adapter-mariadb": "^7.8.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@supabase/supabase-js": "^2.49.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.0",
    "ejs": "^3.1.10",
    "express": "^4.21.0",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.3",
    "mariadb": "^3.5.3",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.22.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "prisma": "^7.8.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "prisma"
    ]
  }
}
